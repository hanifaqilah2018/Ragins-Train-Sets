//Vehicle
item (FEAT_TRAINS, Item_MU_Trailer, 0) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
        refit_cost:                     0;
        climates_available:             ALL_CLIMATES;
        bitmask_vehicle_info:          	0;
        misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK);

        track_type:                     [OHLE_AC, OHLE_DC, SAA3, RAIL];
		running_cost_base: 				RUNNING_COST_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;

        name:                           string(STR_MU_TRAILER);
        introduction_date:              date(1890,1,1);
        model_life:                     VEHICLE_NEVER_EXPIRES;
        length:                         8;

        weight:                         0 ton;
        speed:                          0 mph;
		power:                          0 hp;
        cost_factor:                    100;
        running_cost_factor:            10;

        refittable_cargo_classes:       bitmask();
        default_cargo_type:             PASS;
        cargo_capacity:                 100;
        loading_speed: 					30;

    }
    graphics {
        default:                        spriteset_MU_trailer;
        purchase:                       spriteset_MU_Purchase;
        additional_text: 				string(STR_MU_TRAILER_INFO);

}
}

//ID
const SingaporeMetro_1980_ID = 3400;
//introduction_date
const SingaporeMetro_1980_IntroDate = date(1987, 1, 1);
//speed
const SingaporeMetro_1980_Speed = 90;
//cost_factor
const SingaporeMetro_1980_CostFactor = 22;
//running_cost_factor
const SingaporeMetro_1980_RunningCostFactor = 56;
//Cargo Capacity
const SingaporeMetro_1980_CargoCapacity = 191;
//power
const SingaporeMetro_1980_Power = 1000; //MU power is for 2 individual vehicles
//weight
const SingaporeMetro_1980_Weight = 35;

//SingaporeMetro_1980_Liv0
spriteset(spriteset_SingaporeMetro_1980_Liv0_Purchase,   "gfx/SingaporeMetro_1980_Liv0.png") {template_Purchase_88mu(7, 21)}
spriteset(spriteset_SingaporeMetro_1980_Liv0_Lead,   "gfx/SingaporeMetro_1980_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_SingaporeMetro_1980_Liv0_Trailer,   "gfx/SingaporeMetro_1980_Liv0.png") {template_8_repeat(7, 69)}

const SingaporeMetro_1980_ID_Liv0 = (SingaporeMetro_1980_ID + Liv0_ID);

item(FEAT_TRAINS, Item_SingaporeMetro_1980_Liv0, SingaporeMetro_1980_ID_Liv0) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     SAA3;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_SingaporeDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_SINGAPOREMETRO_1980);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              SingaporeMetro_1980_IntroDate;		
		length:                         8;
		
		loading_speed:					Heavy_Metro_LoadingSpeed;
		speed:							SingaporeMetro_1980_Speed km/h;
		cost_factor:					(SingaporeMetro_1980_CostFactor * 2);
		running_cost_factor:			(SingaporeMetro_1980_RunningCostFactor * 2);
//		cargo_capacity: 				(SingaporeMetro_1980_CargoCapacity / param_capacity_mod);
		power:							SingaporeMetro_1980_Power;
		weight:							SingaporeMetro_1980_Weight;

//        variant_group: 					Item_SingaporeMetro_1980_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						spriteset_SingaporeMetro_1980_Liv0_Lead;
        purchase: 						spriteset_SingaporeMetro_1980_Liv0_Purchase;
        additional_text: 				string(STR_INFO_SINGAPOREMETRO_1980);
		cargo_capacity: 				(SingaporeMetro_1980_CargoCapacity / param_capacity_mod);
}
        livery_override (Item_MU_Trailer) {
        default:                        spriteset_SingaporeMetro_1980_Liv0_Trailer;
        length:                         8;
        cargo_capacity:                 (SingaporeMetro_1980_CargoCapacity / param_capacity_mod);
        power:                          (SingaporeMetro_1980_Power /2);
		weight:                        	SingaporeMetro_1980_Weight;
		running_cost_factor:            SingaporeMetro_1980_RunningCostFactor;
    }
}

