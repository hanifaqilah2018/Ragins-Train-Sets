		speed:							SingaporeMetro_2000_Speed km/h;
		cost_factor:					(SingaporeMetro_2000_CostFactor * 2);
		running_cost_factor:			(SingaporeMetro_2000_RunningCostFactor * 2);
//		cargo_capacity: 				(SingaporeMetro_2000_CargoCapacity / param_capacity_mod);
		power:							SingaporeMetro_2000_Power;
		weight:							SingaporeMetro_2000_Weight;

        variant_group: 					Item_SingaporeMetro_2000_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						spriteset_SingaporeMetro_2000_Liv1_Lead;
        purchase: 						spriteset_SingaporeMetro_2000_Liv1_Purchase;
        additional_text: 				string(STR_INFO_SINGAPOREMETRO_2000);
		cargo_capacity: 				(SingaporeMetro_2000_CargoCapacity / param_capacity_mod);
}
        livery_override (Item_MU_Trailer) {
        default:                        spriteset_SingaporeMetro_2000_Liv1_Trailer;
        length:                         8;
        cargo_capacity:                 (SingaporeMetro_2000_CargoCapacity / param_capacity_mod);
        power:                          (SingaporeMetro_2000_Power /2);
		weight:                        	SingaporeMetro_2000_Weight;
		running_cost_factor:            SingaporeMetro_2000_RunningCostFactor;
    }
}