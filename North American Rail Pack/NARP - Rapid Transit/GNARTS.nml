    }
}

//introduction_date
const HSC_1200Series_DV_IntroDate = date(1981, 1, 1);
//speed
//Add (* 161 / 100) to the value to convert to MPH
const HSC_1200Series_DV_Speed = 65;
//cost_factor
const HSC_1200Series_DV_CostFactor = 21;
//running_cost_factor
const HSC_1200Series_DV_RunningCostFactor = 55;
//Cargo Capacity
const HSC_1200Series_DV_CargoCapacity = 187;
//power
const HSC_1200Series_DV_Power_OHLE_DC = 900;
const HSC_1200Series_DV_Power_3RAIL = 900;
//weight
const HSC_1200Series_DV_Weight = 36;

//Pantographs
spriteset(spriteset_HSC_1200Series_Panto_Purchase,   "gfx/HSC_1200Series_Pantographs.png") {template_Purchase_88mu(7, 21)}
spriteset(spriteset_HSC_1200Series_PantoUp,   "gfx/HSC_1200Series_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_HSC_1200Series_PantoUp_r,   "gfx/HSC_1200Series_Pantographs.png") {template_8_r(7, 69)}
spriteset(spriteset_HSC_1200Series_PantoDown,   "gfx/HSC_1200Series_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_HSC_1200Series_PantoDown_r,   "gfx/HSC_1200Series_Pantographs.png") {template_8_r(7, 39)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_HSC_1200Series_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_HSC_1200Series_PantoDown;
 1: spriteset_HSC_1200Series_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_HSC_1200Series_Rw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_HSC_1200Series_PantoDown_r; //might need switching back to just panto down
 1: spriteset_HSC_1200Series_PantoUp_r;
}

//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_power_1, tile_powers_railtype("OHLE_DC")) {
            1: return HSC_1200Series_DV_Power_OHLE_DC;
        }
        switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_power_0, tile_powers_railtype("SAA3")) {
            1: return HSC_1200Series_DV_Power_3RAIL;
                return switch_HSC_1200Series_power_1;
        }
		
		switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Trailer_power_1, tile_powers_railtype("OHLE_DC")) {
            1: return HSC_1200Series_DV_Power_OHLE_DC;
        }
        switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Trailer_power_0, tile_powers_railtype("SAA3")) {
            1: return HSC_1200Series_DV_Power_3RAIL;
                return switch_HSC_1200Series_Trailer_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_DC)
                    | (HSC_1200Series_DV_Power_OHLE_DC << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (HSC_1200Series_DV_Power_3RAIL << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_HSC_1200SERIES_DV));
        }

//HSC_1200Series_Liv0
//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Purchase;
	1: spriteset_HSC_1200Series_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Lead;
	1: switch_HSC_1200Series_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Lead;
	1: switch_HSC_1200Series_Fw_railtype;
}

//D Rear
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_DrivingTrailerStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Lead;
    1: spriteset_HSC_1200Series_PantoDown;
}
//N Lead
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Lead;
	1: switch_HSC_1200Series_Fw_railtype;
}
//N Rear
switch (FEAT_TRAINS, SELF, switch_HSC_1200Series_Liv0_NonControlMotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_HSC_1200Series_Liv0_Lead_r;
	1: switch_HSC_1200Series_Rw_railtype;
}

//Backward
switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_HSC_1200Series_Liv0_NonControlMotorStack_r;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_HSC_1200Series_Liv0_NonControlMotorStack;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_HSC_1200Series_Liv0_NonControlMotorStack_r;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_0_r, position_in_vehid_chain % 2){
    1 : spriteset_HSC_1200Series_Liv0_Trailer;
    return switch_HSC_1200Series_Liv0_NonControlMotorStack;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_1r_r, position_in_vehid_chain_from_end % 2){
    1 : switch_HSC_1200Series_Liv0_NonControlMotorStack;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_HSC_1200Series_Liv0_pantocheck_at_1_r;
    return sw_HSC_1200Series_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : spriteset_HSC_1200Series_Liv0_Trailer;
    return sw_HSC_1200Series_Liv0_pantocheck_at_0_r;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_HSC_1200Series_Liv0_pantocheck_at_2_r;
    return sw_HSC_1200Series_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_HSC_1200Series_Liv0_Trailer;
    3 : sw_HSC_1200Series_Liv0_pantocheck_at_1_r;
    4 : sw_HSC_1200Series_Liv0_sidecheck_4_r;
    5 : sw_HSC_1200Series_Liv0_pantocheck_at_2_r;
    6 .. 7 : sw_HSC_1200Series_Liv0_sidecheck_6_r;
    return sw_HSC_1200Series_Liv0_sidecheck_other_r;
}

//Forward

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_HSC_1200Series_Liv0_NonControlMotorStack_r;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_HSC_1200Series_Liv0_NonControlMotorStack;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_HSC_1200Series_Liv0_NonControlMotorStack_r;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_HSC_1200Series_Liv0_NonControlMotorStack;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_HSC_1200Series_Liv0_pantocheck_at_1;
    return sw_HSC_1200Series_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_HSC_1200Series_Liv0_pantocheck_at_1;
    return spriteset_HSC_1200Series_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_HSC_1200Series_Liv0_pantocheck_at_2;
    return sw_HSC_1200Series_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_HSC_1200Series_Liv0_Trailer;
    3 : sw_HSC_1200Series_Liv0_pantocheck_at_1;
    4 : sw_HSC_1200Series_Liv0_sidecheck_4;
    5 : sw_HSC_1200Series_Liv0_pantocheck_at_2;
    6 .. 7 : sw_HSC_1200Series_Liv0_sidecheck_6;
    return sw_HSC_1200Series_Liv0_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : switch_HSC_1200Series_Liv0_MotorStack;        //Front panto
    return switch_HSC_1200Series_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : sw_HSC_1200Series_Liv0_panto_direction_r;        //Not flipped, give Panto
    return switch_HSC_1200Series_Liv0_DrivingTrailerStack_r;    //Flipped, no panto //This line was changes from Motorstack_r to DrivingTrailerStack_r
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_frontcheck_r, position_in_vehid_chain){
    0: sw_HSC_1200Series_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return sw_HSC_1200Series_Liv0_panto_flipcheck_r; //More Checks
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_HSC_1200Series_Liv0_MotorStack;        //Front panto
    return switch_HSC_1200Series_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_HSC_1200Series_Liv0_panto_direction;        //Not flipped, give Panto
    return switch_HSC_1200Series_Liv0_DrivingTrailerStack_r;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_HSC_1200Series_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_HSC_1200Series_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_HSC_1200Series_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, sw_HSC_1200Series_Liv0_directioncheck, vehicle_is_reversed){
    0: sw_HSC_1200Series_Liv0_frontcheck; //We are going forwards
    return sw_HSC_1200Series_Liv0_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_HSC_1200Series_Liv0_revcheck, vehicle_is_reversed){
    0 : sw_HSC_1200Series_Liv0_lencheck;
    return sw_HSC_1200Series_Liv0_lencheck_r;
}

//HSC_1200Series_DV_Liv0
item(FEAT_TRAINS, Item_HSC_1200Series_DV_Liv0, 16200) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                    	[OHLE_AC, SAA3];
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_ProposalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_HSC_1200SERIES_DV);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              HSC_1200Series_DV_IntroDate;		
		length:                         8;
		
		loading_speed:					1;
		speed:							1;
		//cost_factor:					1;
		//running_cost_factor:			1;
		cargo_capacity: 				1;
		power:							1;
		weight:							1;

//        variant_group: 					Item_HSC_1200Series_DV_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_HSC_1200Series_Liv0_directioncheck;
        purchase: 						switch_HSC_1200Series_Liv0_PurchaseStack;
        additional_text: 				switch_HSC_1200Series_buy_menu_additional_text;
		visual_effect_and_powered: 		switch_HSC_1200Series_effect_spawn_model_and_powered;
		loading_speed:					return Heavy_Metro_LoadingSpeed;
		speed:							return [HSC_1200Series_DV_Speed * 161 / 100];
		cost_factor:					return [HSC_1200Series_CostFactor * 2];
		running_cost_factor:			return HSC_1200Series_DV_RunningCostFactor;
		cargo_capacity:                 return [HSC_1200Series_CargoCapacity / param_capacity_mod];
		power:							return switch_HSC_1200Series_power_0;
		weight:							return HSC_1200Series_DV_Weight;
}
        livery_override (Item_MU_Trailer) { // <- Override the appearance and stats of Item_FAI_WAGON_MU_COACH when attached, to make it fit the MU's appearance and stats
        default:                        sw_HSC_1200Series_Liv0_revcheck; // <- This tells the game that when attached, the livery_override wagon needs to use this sprite
        length:                         8;
        cargo_capacity:                 [HSC_1200Series_CargoCapacity / param_capacity_mod];
        power:                          switch_HSC_1200Series_Trailer_power_0 () / 2;
		weight:                        	HSC_1200Series_DV_Weight;
		running_cost_factor:            [HSC_1200Series_DV_RunningCostFactor / 2];
    }
}