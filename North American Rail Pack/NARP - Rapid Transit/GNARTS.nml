const Heavy_Metro_LoadingSpeed = 45;

spriteset(spriteset_MU_Purchase,   "gfx/MU_Carriage.png") {template_Purchase_8(7, 21)}
spriteset(spriteset_MU_trailer,   "gfx/MU_Carriage.png") {template_8_repeat(7, 39)}

//Vehicle
item (FEAT_TRAINS, Item_MU_Trailer, 0) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
        refit_cost:                     0;
        climates_available:             ALL_CLIMATES;
        bitmask_vehicle_info:          	0;
        misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK);

        track_type:                     [OHLE_AC, OHLE_DC, SAA3, RAIL];
		running_cost_base: 				RUNNING_COST_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;

        name:                           string(STR_MU_TRAILER);
        introduction_date:              date(1890,1,1);
        model_life:                     VEHICLE_NEVER_EXPIRES;
        length:                         8;

        weight:                         0 ton;
        speed:                          0 mph;
		power:                          0 hp;
        cost_factor:                    100;
        running_cost_factor:            10;

        refittable_cargo_classes:       bitmask();
        default_cargo_type:             PASS;
        cargo_capacity:                 100;
        loading_speed: 					30;

    }
    graphics {
        default:                        spriteset_MU_trailer;
        purchase:                       spriteset_MU_Purchase;
        additional_text: 				string(STR_MU_TRAILER_INFO);

}
}

//introduction_date
const BrooklynGateCar_IntroDate = date(1890, 1, 1);
//speed
const BrooklynGateCar_Speed = 35;
//cost_factor
const BrooklynGateCar_CostFactor = 11;
//running_cost_factor
const BrooklynGateCar_RunningCostFactor = 28;
//Cargo Capacity
const BrooklynGateCar_CargoCapacity = 95;
//power
const BrooklynGateCar_Power = 120;
//weight
const BrooklynGateCar_Weight = 28;

//BrooklynGateCar_Liv0
spriteset(spriteset_BrooklynGateCar_Liv0_Purchase,   "gfx/BrooklynGateCar_Liv0.png") {template_Purchase_6(7, 21)}
spriteset(spriteset_BrooklynGateCar_Liv0,   "gfx/BrooklynGateCar_Liv0.png") {template_6_repeat(7, 39)} // <- Define a wagon, in this case the cab

item(FEAT_TRAINS, Item_BrooklynGateCar_Liv0, 5000) {
    property {		
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     SAA3;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_BROOKLYNGATECAR);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              BrooklynGateCar_IntroDate;		
		length:                         6;
		
		loading_speed:					1;
		speed:							1;
		//cost_factor:					1;
		//running_cost_factor:			1;
		cargo_capacity: 				1;
		power:							1;
		weight:							1;

//        variant_group: 					Item_BrooklynGateCar_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						spriteset_BrooklynGateCar_Liv0;
        purchase: 						spriteset_BrooklynGateCar_Liv0_Purchase;
        additional_text: 				string(STR_INFO_BROOKLYNGATECAR);
		reverse_build_probability: 		return 50;
		loading_speed:					return Heavy_Metro_LoadingSpeed;
		speed:							return [BrooklynGateCar_Speed * 161 / 100];
		cost_factor:					return BrooklynGateCar_CostFactor;
		running_cost_factor:			return BrooklynGateCar_RunningCostFactor;
		cargo_capacity:                 return BrooklynGateCar_CargoCapacity;
		power:							return BrooklynGateCar_Power;
		weight:							return BrooklynGateCar_Weight;
}
}

