}

switch(FEAT_TRAINS, SELF, switch_Bombardier_MR90_Liv0_Rw_railtype, tile_powers_railtype("OHLE_AC")) {
 0: spriteset_Bombardier_MR90_PantoDown_r; //might need switching back to just panto down
 1: spriteset_Bombardier_MR90_PantoUp_r;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_Bombardier_MR90_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Bombardier_MR90_Liv0_lead;
	1: switch_Bombardier_MR90_Liv0_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_Bombardier_MR90_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Bombardier_MR90_Liv0_lead;
	1: switch_Bombardier_MR90_Liv0_Fw_railtype;
}

//N Lead
switch (FEAT_TRAINS, SELF, switch_Bombardier_MR90_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Bombardier_MR90_Liv0_Trailer;
	1: switch_Bombardier_MR90_Liv0_Fw_railtype;
