//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 1280;
        }
        switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_power_0, tile_powers_railtype("SAA3")) {
            1: return 1280;
                return switch_Budd_Cosmopolitan_Liv0_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (1280 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (1280 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_BUDD_COSMOPOLITAN));
        }

