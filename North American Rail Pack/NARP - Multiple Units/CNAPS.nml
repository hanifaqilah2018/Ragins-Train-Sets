    0: sw_Pullman_Wickerliner_Liv0_frontcheck; //We are going forwards
    return sw_Pullman_Wickerliner_Liv0_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_Pullman_Wickerliner_Liv0_revcheck, vehicle_is_reversed){
    0 : sw_Pullman_Wickerliner_Liv0_lencheck;
    return sw_Pullman_Wickerliner_Liv0_lencheck_r;
}

item(FEAT_TRAINS, Item_Pullman_Wickerliner_Liv0, 13120) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        refittable_cargo_classes:        CC_PASSENGERS;
        cargo_allow_refit:                [PASS, TOUR];

        track_type:                        OHLE_DC;
        running_cost_base:                RUNNING_COST_ELECTRIC;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
        dual_headed:                    1; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_PULLMAN_WICKERLINER);
        introduction_date:                date(1926,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        64 ton;
        speed:                            75 mph;
        power:                            1200 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     11;
        running_cost_factor:             113;
        cargo_capacity:                  136/param_capacity_mod;
        loading_speed: 35;

//        variant_group: Item_Pullman_Wickerliner_Liv0;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: sw_Pullman_Wickerliner_Liv0_directioncheck;
        purchase: spriteset_Pullman_Wickerliner_Liv0_purchase;
        additional_text: string(STR_INFO_PULLMAN_WICKERLINER);
    }
    livery_override (Item_MU_Trailer){
        default                     : sw_Pullman_Wickerliner_Liv0_revcheck ;
        length                      : 8;
        cargo_capacity              : (136/param_capacity_mod) ;
        power                       : 600 ;
		weight:                        64;
		running_cost_factor: 28;

    }
}

