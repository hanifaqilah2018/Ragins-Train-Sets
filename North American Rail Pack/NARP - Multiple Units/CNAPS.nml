spriteset(spriteset_Budd_PioneerIII_Liv0,   "gfx/Budd_PioneerIII_Liv0.png") {template_8(7, 39)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Budd_PioneerIII_Liv0_railtype, tile_powers_railtype("OHLE_AC")) {
 0: spriteset_Budd_PioneerIII_PantoDown;
 1: spriteset_Budd_PioneerIII_PantoUp;
}

//Sprite Stack
switch (FEAT_TRAINS, SELF, switch_Budd_PioneerIII_Liv0_stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_PioneerIII_Liv0;
	1: switch_Budd_PioneerIII_Liv0_railtype;
}


item(FEAT_TRAINS, Item_Budd_PioneerIII_Liv0, 13180) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_PrototypeDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        refittable_cargo_classes:        CC_PASSENGERS;
        cargo_allow_refit:                [PASS, TOUR];

        track_type:                        OHLE_AC;
        running_cost_base:                RUNNING_COST_ELECTRIC;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_BUDD_PIONEERIII);
        introduction_date:                date(1958,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        41 ton;
        speed:                            85 mph;
        power:                            550 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     7;
        running_cost_factor:             128;
        cargo_capacity:                  105/param_capacity_mod;
        loading_speed: 20;

//        variant_group: Item_Budd_PioneerIII_Liv0;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: switch_Budd_PioneerIII_Liv0_stack;
        purchase: spriteset_Budd_PioneerIII_Liv0_Purchase;
        additional_text: string(STR_INFO_BUDD_PIONEERIII);
		reverse_build_probability: return 50;
}
}

