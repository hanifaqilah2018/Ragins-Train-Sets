switch(FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_Fw_railtype, tile_powers_railtype("OHLE_AC")) {
 0: spriteset_Budd_Cosmopolitan_PantoDown;
 1: spriteset_Budd_Cosmopolitan_PantoUp;
}

