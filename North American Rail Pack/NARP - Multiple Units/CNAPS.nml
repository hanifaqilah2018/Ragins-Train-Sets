            1: return 1280;
        }
        switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_power_0, tile_powers_railtype("SAA3")) {
            1: return 1280;
                return switch_Budd_Cosmopolitan_Liv0_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv0_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
