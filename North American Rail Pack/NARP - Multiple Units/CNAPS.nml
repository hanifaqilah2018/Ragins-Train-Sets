item(FEAT_TRAINS, Item_Kawasaki_M8_Liv0, 13580) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        refittable_cargo_classes:        CC_PASSENGERS;
        cargo_allow_refit:                [PASS, TOUR];

        track_type:                        [OHLE_AC, SAA3];
        running_cost_base:                RUNNING_COST_ELECTRIC;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
        dual_headed:                    1; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_KAWASAKI_M8);
        introduction_date:                date(2011,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        63 ton;
        speed:                            100 mph;
        power:                            2160 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     15;
        running_cost_factor:             160;
        cargo_capacity:                  145/param_capacity_mod;
        loading_speed: 20;

//        variant_group: Item_Kawasaki_M8_Liv0;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: sw_Kawasaki_M8_Liv0_directioncheck;
        purchase: spriteset_Kawasaki_M8_Liv0_purchase;
        power: switch_Kawasaki_M8_Liv0_power_0;
        visual_effect_and_powered: switch_Kawasaki_M8_Liv0_effect_spawn_model_and_powered;
        additional_text: switch_Kawasaki_M8_Liv0_buy_menu_additional_text;
    }
    livery_override (Item_MU_Trailer){
        default                     : sw_Kawasaki_M8_Liv0_revcheck ;
        length                      : 8;
        cargo_capacity              : (120/param_capacity_mod) ;
        power                       : 1080 ;
		weight:                        63;
		running_cost_factor: 40;

    }
}

