item(FEAT_TRAINS, Item_Budd_Cosmopolitan_Liv3, 13343) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        refittable_cargo_classes:        CC_PASSENGERS;
        cargo_allow_refit:                [PASS, TOUR];

        track_type:                        [OHLE_AC, SAA3];
        running_cost_base:                RUNNING_COST_ELECTRIC;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
        dual_headed:                    1; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_BUDD_COSMOPOLITAN);
        introduction_date:                date(1973,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        50 ton;
        speed:                            100 mph;
        power:                            1280 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     13;
        running_cost_factor:             170;
        cargo_capacity:                  120/param_capacity_mod;
        loading_speed: 30;

        variant_group: Item_Budd_Cosmopolitan_Liv0;
        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: sw_Budd_Cosmopolitan_Liv3_directioncheck;
        purchase: switch_Budd_Cosmopolitan_Liv3_PurchaseStack;
        power: switch_Budd_Cosmopolitan_Liv3_power_0;
        visual_effect_and_powered: switch_Budd_Cosmopolitan_Liv3_effect_spawn_model_and_powered;
        additional_text: switch_Budd_Cosmopolitan_Liv3_buy_menu_additional_text;
    }
    livery_override (Item_MU_Trailer){
        default                     : sw_Budd_Cosmopolitan_Liv3_revcheck ;
        length                      : 8;
        cargo_capacity              : (120/param_capacity_mod) ;
        power                       : 640 ;
		weight:                        50;
		running_cost_factor: 43;

    }
}

//Budd_Cosmopolitan_Liv4
spriteset(spriteset_Budd_Politan_Liv4_purchase,   "gfx/Budd_Politan_Liv4.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Budd_Politan_Liv4_lead,   "gfx/Budd_Politan_Liv4.png") {template_8(7, 39)}
spriteset(spriteset_Budd_Politan_Liv4_lead_r,   "gfx/Budd_Politan_Liv4.png") {template_8_r(7, 39)}
spriteset(spriteset_Budd_Politan_Liv4_Trailer,   "gfx/Budd_Politan_Liv4.png") {template_8_repeat(7, 69)}

//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv4_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 1280;
        }
        switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv4_power_0, tile_powers_railtype("SAA3")) {
            1: return 1280;
                return switch_Budd_Cosmopolitan_Liv4_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv4_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv4_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (1280 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (1280 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_BUDD_COSMOPOLITAN));
        }

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv4_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv4_purchase;
	1: spriteset_Budd_Politan_3RShoes_Purchase;
    2: spriteset_Budd_Cosmopolitan_Greebles_Purchase;
	3: spriteset_Budd_Cosmopolitan_Panto_Purchase;
}

