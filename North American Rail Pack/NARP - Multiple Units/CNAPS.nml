        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_BUDD_METROPOLITAN);
        introduction_date:                date(1968,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        48 ton;
        speed:                            100 mph;
        power:                            1184 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     13;
        running_cost_factor:             170;
        cargo_capacity:                  140/param_capacity_mod;
        loading_speed: 30;

        variant_group: Item_Budd_Metropolitan_Liv0;
        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: switch_Budd_Metropolitan_Liv1_position;
        purchase: switch_Budd_Metropolitan_Liv1_PurchaseStack;
        additional_text: string(STR_INFO_BUDD_METROPOLITAN);
}
        livery_override (Item_MU_Trailer) { // <- Override the appearance and stats of Item_FAI_WAGON_MU_COACH when attached, to make it fit the MU's appearance and stats
        default:                        switch_Budd_Metropolitan_Liv1_TrailerStack; // <- This tells the game that when attached, the livery_override wagon needs to use this sprite
        length:                            8;
        cargo_capacity:                   (140/param_capacity_mod);
        power:                            592;
		running_cost_factor: 42;
    }
}

//Budd_Metropolitan_Liv2
//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Budd_Metropolitan_Liv2_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv2_purchase;
	1: spriteset_Budd_Politan_3RShoes_Purchase;
}
//Lead
switch (FEAT_TRAINS, SELF, switch_Budd_Metropolitan_Liv2_LeadStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv2_lead;
	1: spriteset_Budd_Politan_LightsFw;
	2: spriteset_Budd_Politan_3RShoes;
}
//Rear
switch (FEAT_TRAINS, SELF, switch_Budd_Metropolitan_Liv2_RearStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv2_lead;
	1: spriteset_Budd_Politan_LightsFw;
	2: spriteset_Budd_Politan_3RShoes;
}

//T
switch (FEAT_TRAINS, SELF, switch_Budd_Metropolitan_Liv2_TrailerStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv2_Trailer;
    1: spriteset_Budd_Politan_3RShoes;
}

switch(FEAT_TRAINS, SELF, switch_Budd_Metropolitan_Liv2_position, position_in_consist_from_end){ // <- This code tells the game whether to use the cab or flipped cab, based on if they're right at the end or not
    0:    switch_Budd_Metropolitan_Liv2_RearStack;
    switch_Budd_Metropolitan_Liv2_LeadStack;
}


