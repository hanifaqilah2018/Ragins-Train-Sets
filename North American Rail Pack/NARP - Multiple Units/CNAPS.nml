spriteset(spriteset_Budd_Politan_Liv1_purchase,   "gfx/Budd_Politan_Liv1.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Budd_Politan_Liv1_lead,   "gfx/Budd_Politan_Liv1.png") {template_8(7, 39)}
spriteset(spriteset_Budd_Politan_Liv1_lead_r,   "gfx/Budd_Politan_Liv1.png") {template_8_r(7, 39)}
spriteset(spriteset_Budd_Politan_Liv1_Trailer,   "gfx/Budd_Politan_Liv1.png") {template_8_repeat(7, 69)}

//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 1280;
        }
        switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_power_0, tile_powers_railtype("SAA3")) {
            1: return 1280;
                return switch_Budd_Cosmopolitan_Liv1_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (1280 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (1280 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_BUDD_COSMOPOLITAN));
        }

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Budd_Cosmopolitan_Liv1_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Budd_Politan_Liv1_purchase;
	1: spriteset_Budd_Politan_3RShoes_Purchase;
    2: spriteset_Budd_Cosmopolitan_Greebles_Purchase;
	3: spriteset_Budd_Cosmopolitan_Panto_Purchase;
}

