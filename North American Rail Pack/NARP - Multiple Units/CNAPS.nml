spriteset(spriteset_Kawasaki_M8_Panto_Purchase,   "gfx/Kawasaki_M8_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Kawasaki_M8_PantoUp,   "gfx/Kawasaki_M8_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Kawasaki_M8_PantoUp_r,   "gfx/Kawasaki_M8_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_Kawasaki_M8_PantoDown,   "gfx/Kawasaki_M8_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_Kawasaki_M8_PantoDown_r,   "gfx/Kawasaki_M8_Pantographs.png") {template_8_r(7, 69)}

//Kawasaki_M8_Liv0
spriteset(spriteset_Kawasaki_M8_Liv0_purchase,   "gfx/Kawasaki_M8_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Kawasaki_M8_Liv0_lead,   "gfx/Kawasaki_M8_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_Kawasaki_M8_Liv0_Trailer,   "gfx/Kawasaki_M8_Liv0.png") {template_8_repeat(7, 69)}

//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Kawasaki_M8_Liv0_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 2160;
        }
        switch (FEAT_TRAINS, SELF, switch_Kawasaki_M8_Liv0_power_0, tile_powers_railtype("SAA3")) {
            1: return 2160;
                return switch_Kawasaki_M8_Liv0_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Kawasaki_M8_Liv0_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
