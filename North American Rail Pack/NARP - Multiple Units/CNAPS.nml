    return switch_Budd_Cosmopolitan_Liv1_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Budd_Cosmopolitan_Liv1_panto_flipcheck, vehicle_is_flipped){
