//Pantographs
spriteset(spriteset_Pullman_Washboard_PantoDown,   "gfx/Pullman_Washboard_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Pullman_Washboard_PantoUp,   "gfx/Pullman_Washboard_Pantographs.png") {template_8(7, 69)}

//Pullman_Washboard_Liv0
spriteset(spriteset_Pullman_Washboard_Liv0_Purchase,   "gfx/Pullman_Washboard_Liv0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Pullman_Washboard_Liv0,   "gfx/Pullman_Washboard_Liv0.png") {template_8(7, 39)}

//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 600;
        }
        switch (FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_power_0, tile_powers_railtype("SAA3")) {
            1: return 600;
                return switch_Pullman_Washboard_Liv0_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (600 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (600 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_PULLMAN_WASHBOARD));
        }

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_railtype, tile_powers_railtype("OHLE_AC")) {
 0: spriteset_Pullman_Washboard_PantoDown;
 1: spriteset_Pullman_Washboard_PantoUp;
}

//Sprite Stack
switch (FEAT_TRAINS, SELF, switch_Pullman_Washboard_Liv0_stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Pullman_Washboard_Liv0;
	1: switch_Pullman_Washboard_Liv0_railtype;
}


