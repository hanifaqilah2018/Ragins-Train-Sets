//N Rear
switch (FEAT_TRAINS, SELF, switch_Bombardier_MR90_Liv0_NonControlMotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Bombardier_MR90_Liv0_Trailer;
	1: switch_Bombardier_MR90_Liv0_Rw_railtype;
}

//Backward
switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_Bombardier_MR90_Liv0_NonControlMotorStack_r;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_Bombardier_MR90_Liv0_NonControlMotorStack;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_Bombardier_MR90_Liv0_NonControlMotorStack_r;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_0_r, position_in_vehid_chain % 2){
    1 : spriteset_Bombardier_MR90_Liv0_Trailer;
    return switch_Bombardier_MR90_Liv0_NonControlMotorStack;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_1r_r, position_in_vehid_chain_from_end % 2){
    1 : switch_Bombardier_MR90_Liv0_NonControlMotorStack;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Bombardier_MR90_Liv0_pantocheck_at_1_r;
    return sw_Bombardier_MR90_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : spriteset_Bombardier_MR90_Liv0_Trailer;
    return sw_Bombardier_MR90_Liv0_pantocheck_at_0_r;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Bombardier_MR90_Liv0_pantocheck_at_2_r;
    return sw_Bombardier_MR90_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Bombardier_MR90_Liv0_Trailer;
    3 : sw_Bombardier_MR90_Liv0_pantocheck_at_1_r;
    4 : sw_Bombardier_MR90_Liv0_sidecheck_4_r;
    5 : sw_Bombardier_MR90_Liv0_pantocheck_at_2_r;
    6 .. 7 : sw_Bombardier_MR90_Liv0_sidecheck_6_r;
    return sw_Bombardier_MR90_Liv0_sidecheck_other_r;
}

//Forward

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_Bombardier_MR90_Liv0_NonControlMotorStack_r;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Bombardier_MR90_Liv0_NonControlMotorStack;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Bombardier_MR90_Liv0_NonControlMotorStack_r;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Bombardier_MR90_Liv0_NonControlMotorStack;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Bombardier_MR90_Liv0_pantocheck_at_1;
    return sw_Bombardier_MR90_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Bombardier_MR90_Liv0_pantocheck_at_1;
    return spriteset_Bombardier_MR90_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Bombardier_MR90_Liv0_pantocheck_at_2;
    return sw_Bombardier_MR90_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Bombardier_MR90_Liv0_Trailer;
    3 : sw_Bombardier_MR90_Liv0_pantocheck_at_1;
    4 : sw_Bombardier_MR90_Liv0_sidecheck_4;
    5 : sw_Bombardier_MR90_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Bombardier_MR90_Liv0_sidecheck_6;
    return sw_Bombardier_MR90_Liv0_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: switch_Bombardier_MR90_Liv0_MotorStack; //Panto
    return spriteset_Bombardier_MR90_Liv0_lead; //No Panto
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : sw_Bombardier_MR90_Liv0_panto_direction_r_pos;        //Front panto
    return switch_Bombardier_MR90_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : sw_Bombardier_MR90_Liv0_panto_direction_r;        //Not flipped, give Panto
    return switch_Bombardier_MR90_Liv0_MotorStack_r;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_frontcheck_r, position_in_vehid_chain){
    0: sw_Bombardier_MR90_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return sw_Bombardier_MR90_Liv0_panto_flipcheck_r; //More Checks
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Bombardier_MR90_Liv0_MotorStack;        //Front panto
    return switch_Bombardier_MR90_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Bombardier_MR90_Liv0_panto_direction;        //Not flipped, give Panto
    return spriteset_Bombardier_MR90_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Bombardier_MR90_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Bombardier_MR90_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_Bombardier_MR90_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, sw_Bombardier_MR90_Liv0_directioncheck, vehicle_is_reversed){
    0: sw_Bombardier_MR90_Liv0_frontcheck; //We are going forwards
    return sw_Bombardier_MR90_Liv0_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_Bombardier_MR90_Liv0_revcheck, vehicle_is_reversed){
    0 : sw_Bombardier_MR90_Liv0_lencheck;
    return sw_Bombardier_MR90_Liv0_lencheck_r;
}

