item(FEAT_TRAINS, Item_Budd_Cosmopolitan_Liv4, 13344) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        refittable_cargo_classes:        CC_PASSENGERS;
        cargo_allow_refit:                [PASS, TOUR];

        track_type:                        [OHLE_AC, SAA3];
        running_cost_base:                RUNNING_COST_ELECTRIC;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
        dual_headed:                    1; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_BUDD_COSMOPOLITAN);
        introduction_date:                date(1973,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        50 ton;
        speed:                            100 mph;
        power:                            1280 hp;
        tractive_effort_coefficient:     0.7;
        cost_factor:                     13;
        running_cost_factor:             170;
        cargo_capacity:                  120/param_capacity_mod;
        loading_speed: 30;

        variant_group: Item_Budd_Cosmopolitan_Liv0;
        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: sw_Budd_Cosmopolitan_Liv4_directioncheck;
        purchase: switch_Budd_Cosmopolitan_Liv4_PurchaseStack;
        power: switch_Budd_Cosmopolitan_Liv4_power_0;
        visual_effect_and_powered: switch_Budd_Cosmopolitan_Liv4_effect_spawn_model_and_powered;
        additional_text: switch_Budd_Cosmopolitan_Liv4_buy_menu_additional_text;
    }
    livery_override (Item_MU_Trailer){
        default                     : sw_Budd_Cosmopolitan_Liv4_revcheck ;
        length                      : 8;
        cargo_capacity              : (120/param_capacity_mod) ;
        power                       : 640 ;
		weight:                        50;
		running_cost_factor: 43;

    }
}

//Pantographs
spriteset(spriteset_NipponSharyo_EMU_PantoUp,   "gfx/NipponSharyo_EMU_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_NipponSharyo_EMU_PantoUp_r,   "gfx/NipponSharyo_EMU_Pantographs.png") {template_8_r(7, 69)}
spriteset(spriteset_NipponSharyo_EMU_PantoDown,   "gfx/NipponSharyo_EMU_Pantographs.png") {template_8_repeat(7, 39)}

//NipponSharyo_EMU_Liv0
spriteset(spriteset_NipponSharyo_EMU_Liv0_Purchase,   "gfx/NipponSharyo_EMU_Liv0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_NipponSharyo_EMU_Liv0,   "gfx/NipponSharyo_EMU_Liv0.png") {template_8_repeat(7, 39)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_NipponSharyo_EMU_Liv0_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_NipponSharyo_EMU_PantoDown;
 1: spriteset_NipponSharyo_EMU_PantoUp;
}

switch (FEAT_TRAINS, SELF, switch_NipponSharyo_EMU_Liv0_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_NipponSharyo_EMU_Liv0;
    1: switch_NipponSharyo_EMU_Liv0_Fw_railtype;
}

switch(FEAT_TRAINS, SELF, switch_NipponSharyo_EMU_Liv0_r_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_NipponSharyo_EMU_PantoDown;
 1: spriteset_NipponSharyo_EMU_PantoUp_r;
}

switch (FEAT_TRAINS, SELF, switch_NipponSharyo_EMU_Liv0_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_NipponSharyo_EMU_Liv0;
    1: switch_NipponSharyo_EMU_Liv0_r_railtype;
}

switch(FEAT_TRAINS, SELF, switch_NipponSharyo_EMU_Liv0_position, vehicle_is_flipped) {
 0: switch_NipponSharyo_EMU_Liv0_Fw;
 1: switch_NipponSharyo_EMU_Liv0_r;
}

