//Backward
switch(FEAT_TRAINS, SELF, sw_Budd_Cosmopolitan_Liv2_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_Budd_Cosmopolitan_Liv2_NonControlMotorStack_r;
    return switch_Budd_Cosmopolitan_Liv2_TrailerStack;
}
