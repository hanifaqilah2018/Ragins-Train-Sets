grf {
    grfid: "ZM\11\03";
    name: string(STR_GRF_NAME);
    desc: string(STR_GRF_DESC);
    version: 1;
    min_compatible_version: 0;
}

if (!extended_feature_test("action3_signals_custom_signal_sprites")) {
	error(FATAL, string(STR_UNSUPPORTED_VERSION));
}
//templates use the following format :
// template [template name](x,y){
//	[ x, y, sx, sy, ox, oy]
// where the first x and y are the starting coordinates of a sprite
// sx and sy are size in x and y respectively
// ox and oy are offset in x and y respectively
//}

template template_signal_6tall(x,y){
//left_x, upper_y, width, height, offset_x, offset_y
    //                            more negative to shift left
    //                                            more negative to shift up
	[ x, y, 5, 26, -1, -25,ANIM]
	[ x+6, y, 6, 26, -1, -25,ANIM]
	[ x+13, y, 6, 26, -1, -25,ANIM]
	[ x+20, y, 5, 26, -6, -25,ANIM]
	[ x+26, y, 5, 26, -2, -25,ANIM]
	[ x+32, y, 5, 26, -3, -23,ANIM]
	[ x+38, y, 6, 26, -2, -25,ANIM]
	[ x+45, y, 6, 26, -1, -25,ANIM]
}

template template_signal_tall(x,y){
//left_x, upper_y, width, height, offset_x, offset_y
    //                            more negative to shift left
    //                                            more negative to shift up
	[ x, y, 17, 26, -7, -25,ANIM]
	[ x+18, y, 18, 26, -7, -25,ANIM]
	[ x+37, y, 17, 26, -6, -25,ANIM]
	[ x+55, y, 17, 26, -14, -25,ANIM]
	[ x+73, y, 17, 26, -8, -25,ANIM]
	[ x+91, y, 17, 26, -9, -23,ANIM]
	[ x+109, y, 18, 26, -8, -25,ANIM]
	[ x+128, y, 18, 26, -7, -25,ANIM]
}


//TwoAspect_Block
spriteset(TwoAspect_Block_stop, "gfx/TwoAspect_Block.png"){template_signal_6tall(7,7)}
spriteset(TwoAspect_Block_clear, "gfx/TwoAspect_Block.png"){template_signal_6tall(7,36)}

//This switch decides which spriteset to use for each signal aspect for one signal type (this will be used for block electric, style one)
switch(FEAT_SIGNALS, SELF, TwoAspect_Block, getbits(extra_callback_info2, 0, 8)){
	00: TwoAspect_Block_stop;
	01:	TwoAspect_Block_clear;
	02:	TwoAspect_Block_clear;
	03:	TwoAspect_Block_clear;
	04:	TwoAspect_Block_clear;
	05:	TwoAspect_Block_clear;
}

