switch(FEAT_SIGNALS, SELF, sw_NARPSignals, signal_style){
	01: TwoAspect;
	02: Speed_Searchlight;
	03: Speed_Twin_Searchlight;
	04: Speed_Trilight;
	05: Speed_Twin_Trilight;
	06: Speed_ColourLight;
	07: Speed_Twin_ColourLight;
	08: Speed_PositionLight;
	09: Speed_Twin_PositionLight;
	10: Speed_PositionColourLight;
	11: Speed_Twin_PositionColourLight;
	14: Underground;
}

item (FEAT_SIGNALS, custom_signals, 0) { 
	property{
		extra_aspects:		4;	//Number of extra aspects to be used across all signal types (0=only red/green, 1=red/yellow/green etc). Set it to the max of all your signal types
		
		define_style:		1;
		style_name:			string(STR_TWOASPECT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
				
		define_style:		2;
		style_name:			string(STR_SPEED_SEARCHLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		3;
		style_name:			string(STR_SPEED_TWIN_SEARCHLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		4;
		style_name:			string(STR_SPEED_TRILIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		5;
		style_name:			string(STR_SPEED_TWIN_TRILIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		6;
		style_name:			string(STR_SPEED_COLOURLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		7;
		style_name:			string(STR_SPEED_TWIN_COLOURLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		8;
		style_name:			string(STR_SPEED_POSITIONLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		9;
		style_name:			string(STR_SPEED_TWIN_POSITIONLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		10;
		style_name:			string(STR_SPEED_POSITIONCOLOURLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		11;
		style_name:			string(STR_SPEED_TWIN_POSITIONCOLOURLIGHT);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);
		
		define_style:		14;
		style_name:			string(STR_UNDERGROUND);
		style_electric_enabled: bitmask(SIGNAL_TYPE_NORMAL, SIGNAL_TYPE_PBS, SIGNAL_TYPE_PBS_ONEWAY, SIGNAL_TYPE_NO_ENTRY);

	}

    graphics {
        sw_NARPSignals;
    }
}
