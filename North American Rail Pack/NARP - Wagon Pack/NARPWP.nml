spriteset(spriteset_Gen3_Hopper_Loadh,   "gfx/Gen3_Hopper_Load.png") {template_6_repeat(7, 39)}
spriteset(spriteset_Gen3_Hopper_Loadf,   "gfx/Gen3_Hopper_Load.png") {template_6_repeat(7, 69)}

switch(FEAT_TRAINS, SELF, switch_Gen3_Hopper_loadcheck, cargo_count * (100 / cargo_capacity)){
	1..50	: spriteset_Gen3_Hopper_Loadh ;
	51..100	: spriteset_Gen3_Hopper_Loadf ;
}

switch (FEAT_TRAINS, SELF, switch_Gen3_Hopper_recolour_load, STORE_TEMP(switch_generic_recolour(), 0x100)) {
    return switch_Gen3_Hopper_loadcheck;
}

//Gen3_Hopper_Liv0
spriteset(spriteset_Gen3_Hopper_Liv0_Purchase,   "gfx/Gen3_Hopper_Liv0_0.png") {template_purchase_6(7, 21)}

spriteset(spriteset_Gen3_Hopper_Liv0_0,   "gfx/Gen3_Hopper_Liv0_0.png") {template_6_repeat(7, 39)}
spriteset(spriteset_Gen3_Hopper_Liv0_1,   "gfx/Gen3_Hopper_Liv0_1.png") {template_6_repeat(7, 39)}

 random_switch(FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_Random){
    1 : spriteset_Gen3_Hopper_Liv0_0;
	1 : spriteset_Gen3_Hopper_Liv0_1;
}

switch (FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_CargoStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen3_Hopper_Liv0_Random;
    1: switch_Gen3_Hopper_recolour_load;
}

switch (FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen3_Hopper_Liv0_Random;
	1: spriteset_6_Old_EOTD;
    2: switch_Gen3_Hopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen3_Hopper_Liv0_RearStack1;
    return switch_Gen3_Hopper_Liv0_CargoStack1;
}

switch (FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_CargoStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen3_Hopper_Liv0_Random;
    1: switch_Gen3_Hopper_recolour_load;
}

switch (FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_RearStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen3_Hopper_Liv0_Random;
	1: spriteset_6_Old_EOTD_r;
    2: switch_Gen3_Hopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen3_Hopper_Liv0_RearStack2;
    return switch_Gen3_Hopper_Liv0_CargoStack2;
}

switch(FEAT_TRAINS, SELF, switch_Gen3_Hopper_Liv0_position, vehicle_is_flipped) {
 0: switch_Gen3_Hopper_Liv0_rearcheck1;
 1: switch_Gen3_Hopper_Liv0_rearcheck2;
}


