grf{
    grfid: "ZM\12\01";
    name: string(STR_GRF_NAME);
    desc: string(STR_GRF_DESCRIPTION);
    version: 3;
    min_compatible_version: 1;
//Purchase Cost Parameter
    param {
        param_purchase_cost {
            type: int;
            name: string(STR_PARAM_PURCHASE_COST);
            desc: string(STR_PARAM_PURCHASE_COST_DESC);
            min_value: 0;
            max_value: 8;
            def_value: 4;
            names: {
                        0: string(STR_PARAM_DIVIDE_16);
                        1: string(STR_PARAM_DIVIDE_8);
                        2: string(STR_PARAM_DIVIDE_4);
                        3: string(STR_PARAM_DIVIDE_2);
                        4: string(STR_PARAM_NORMAL);
                        5: string(STR_PARAM_TIMES_2);
                        6: string(STR_PARAM_TIMES_4);
                        7: string(STR_PARAM_TIMES_8);
                        8: string(STR_PARAM_TIMES_16);
            };
        }
    }
//Running Cost Parameter
     param {
        param_running_cost {
            type: int;
            name: string(STR_PARAM_RUNNING_COST);
            desc: string(STR_PARAM_RUNNING_COST_DESC);
            min_value: 0;
            max_value: 8;
            def_value: 4;
            names: {
                        0: string(STR_PARAM_DIVIDE_16);
                        1: string(STR_PARAM_DIVIDE_8);
                        2: string(STR_PARAM_DIVIDE_4);
                        3: string(STR_PARAM_DIVIDE_2);
                        4: string(STR_PARAM_NORMAL);
                        5: string(STR_PARAM_TIMES_2);
                        6: string(STR_PARAM_TIMES_4);
                        7: string(STR_PARAM_TIMES_8);
                        8: string(STR_PARAM_TIMES_16);
            };
        }
}
//RealDisable
	param {
    param_RealDisable {
     name: string(STR_PARAM_NAME_REALDISABLE);
     desc: string(STR_PARAM_DESC_REALDISABLE);
     type: bool;
     bit: 0;
     def_value: 0;
    }
  }
//PrototypeDisable
	param {
    param_PrototypeDisable {
     name: string(STR_PARAM_NAME_PROTOTYPEDISABLE);
     desc: string(STR_PARAM_DESC_PROTOTYPEDISABLE);
     type: bool;
     bit: 0;
     def_value: 0;
    }
  }
//ProposalDisable
	param {
    param_ProposalDisable {
     name: string(STR_PARAM_NAME_PROPOSALDISABLE);
     desc: string(STR_PARAM_DESC_PROPOSALDISABLE);
     type: bool;
     bit: 0;
     def_value: 0;
    }
  }
//FictionalDisable
	param {
    param_FictionalDisable {
     name: string(STR_PARAM_NAME_FICTIONALDISABLE);
     desc: string(STR_PARAM_DESC_FICTIONALDISABLE);
     type: bool;
     bit: 0;
     def_value: 0;
    }
    }
//3rdRailDisable
	param {
    param_ThirdRailDisable {
     name: string(STR_PARAM_NAME_THIRDRAILDISABLE);
     desc: string(STR_PARAM_DESC_THIRDRAILDISABLE);
     type: bool;
     bit: 0;
     def_value: 1;
    }
    }
//PilbaraDisable
	param {
    param_PilbaraDisable {
     name: string(STR_PARAM_NAME_PILBARADISABLE);
     desc: string(STR_PARAM_DESC_PILBARADISABLE);
     type: bool;
     bit: 0;
     def_value: 1;
    }
    }
//Couplers Control
	param {
    param_Couplers {
     type: int;
            name: string(STR_PARAM_NAME_COUPLERS);
            desc: string(STR_PARAM_DESC_COUPLERS);
            min_value: 0;
            max_value: 2;
            def_value: 2;
            names: {
                        0: string(STR_PARAM_COUPLERS_BUFFERS);
                        1: string(STR_PARAM_COUPLERS_KNUCKLES);
                        2: string(STR_PARAM_TRANSITION);
            };
        }
    }
  }

railtypetable {
    RAIL, 
	SAA3: [ MTRO, SBA3, SCA3, SDA3, "3RDR", "3RDC", MTRO, ELRL], 
	OHLE_DC: [SAAD, SAAE, ELRL], 
	OHLE_AC: [SAAA, SAAE, ELRL], 
	TR_UNIVERSAL: [_AAE, RAIL], 
	BG_RAIL: [BAAN, RAIL], 
	BG_RAIL_ONLY: [BAAN], 
	NG_RAIL: [NAAN, RAIL], 
	NG_RAIL_ONLY: [NAAN], 
	NG_RAIL_OHLE_DC: [NAAD, NAAE, SAAD, SAAE, ELRL], 
	NG_RAIL_ONLY_OHLE_DC: [NAAD, NAAE],
	NG_RAIL_OHLE_AC: [NAAA, NAAE, SAAA, SAAE, ELRL], 
	NG_RAIL_ONLY_OHLE_AC: [NAAA, NAAE],
}

//Basecost Paramater Variables
basecost {
 PR_BUILD_VEHICLE_TRAIN: 	1 + param_purchase_cost - 6;
 PR_BUILD_VEHICLE_WAGON: 	1 + param_purchase_cost - 4;
 PR_RUNNING_TRAIN_ELECTRIC: 3 + param_running_cost - 4;
 PR_RUNNING_TRAIN_DIESEL: 	3 + param_running_cost - 4;
 PR_RUNNING_TRAIN_STEAM: 	0 + param_running_cost - 4;
}

// Fix depot view
traininfo_y_offset = 2;
train_width_32_px = 1;


