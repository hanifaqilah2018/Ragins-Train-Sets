                return switch_Comeng_CL632_3R_Liv0_power_1;}

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_DC)
                    | (3620 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (4290 << 16),
                    0x101
                ),
				STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (3620 << 16),
                    0x102
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_THREE_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_THREE_SOURCES), string(STR_INFO_COMENG_CL632_3R));
        }

//Purchase Sprite Stacker
