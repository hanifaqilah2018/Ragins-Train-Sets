//Clyde_AT42C_Liv0
spriteset(spriteset_Clyde_AT42C_Liv0_Purchase,   "gfx/Clyde_AT42C_Liv0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Clyde_AT42C_Liv0,   "gfx/Clyde_AT42C_Liv0.png") {template_8(7, 39)} // <- Define a wagon, in this case the cab
spriteset(spriteset_Clyde_AT42C_Liv0_r,   "gfx/Clyde_AT42C_Liv0.png") {template_8_r(7, 39)}

spriteset(spriteset_Clyde_AT42C_Liv0A,   "gfx/Clyde_AT42C_Liv0A.png") {template_8(7, 39)} // <- Define a wagon, in this case the cab
spriteset(spriteset_Clyde_AT42C_Liv0A_r,   "gfx/Clyde_AT42C_Liv0A.png") {template_8_r(7, 39)}

//Liv0 Random Forward
random_switch(FEAT_TRAINS, SELF, switch_Clyde_AT42C_Liv0_Random){
    1 : spriteset_Clyde_AT42C_Liv0;
	1 : spriteset_Clyde_AT42C_Liv0A;
}

//Liv0 Random Reversed
random_switch(FEAT_TRAINS, SELF, switch_Clyde_AT42C_Liv0_Random_r){
    1 : spriteset_Clyde_AT42C_Liv0_r;
	1 : spriteset_Clyde_AT42C_Liv0A_r;
}

//Purchase Sprite Stacker
