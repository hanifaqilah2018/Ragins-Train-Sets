//Trains Below!

//Clyde_ML1_Liv0
spriteset(spriteset_Clyde_ML1_Liv0_Purchase,   "gfx/Clyde_ML1_Liv0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Clyde_ML1_Liv0,   "gfx/Clyde_ML1_Liv0.png") {template_8(7, 39)} // <- Define a wagon, in this case the cab
spriteset(spriteset_Clyde_ML1_Liv0_r,   "gfx/Clyde_ML1_Liv0.png") {template_8_r(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_ML1_Liv0_Purchase;
    1: switch_Couplers_8_Purchase;
}

//Forward Stack
switch (FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_Fw_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_ML1_Liv0;
    1: switch_Couplers_8F;
}

//Rear Stack
switch (FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_Rw_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_ML1_Liv0_r;
    1: switch_Couplers_8F_r;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_pair, position_in_vehid_chain % 2) {
 1: switch_Clyde_ML1_Liv0_Rw_Stack;
  switch_Clyde_ML1_Liv0_Fw_Stack;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_rear, position_in_vehid_chain_from_end) {
 0: switch_Clyde_ML1_Liv0_Rw_Stack;
  switch_Clyde_ML1_Liv0_pair;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_ML1_Liv0_position, position_in_consist) {
 0: switch_Clyde_ML1_Liv0_Fw_Stack;
  switch_Clyde_ML1_Liv0_rear;
}

item(FEAT_TRAINS, Item_Clyde_ML1_Liv0, 3250) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        track_type:                        RAIL;
        running_cost_base:                RUNNING_COST_DIESEL;
        engine_class:                     ENGINE_CLASS_DIESEL;
//        ai_special_flag:                AI_FLAG_CARGO;
        dual_headed:                    0; // <- Double Headed, so cab on each end

        visual_effect_and_powered: visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 3, DISABLE_WAGON_POWER);

        name:                            string(STR_NAME_CLYDE_ML1);
        introduction_date:                date(1951,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        108 ton;
        speed:                            145 km/h;
        power:                            1500 hp;
        tractive_effort_coefficient:     0.5;
        cost_factor:                     12;
        running_cost_factor:             95;
		cargo_capacity:                  0;

//        variant_group: Item_Clyde_ML1_Liv0;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: switch_Clyde_ML1_Liv0_position;
//		sound_effect: switch_EMD_16_567;
        purchase: switch_Clyde_ML1_Liv0_Purchase_Stack;
        additional_text: string(STR_INFO_CLYDE_ML1);
}
}

