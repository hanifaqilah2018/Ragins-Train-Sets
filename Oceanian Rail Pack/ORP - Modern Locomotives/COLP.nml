switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_Liv0_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_DC)
                    | (3620 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (4290 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_COMENG_CL632));
        }

