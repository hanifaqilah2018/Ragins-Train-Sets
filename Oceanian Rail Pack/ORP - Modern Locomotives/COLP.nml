//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_GT46CWM_Liv46_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
}

//Forward Stack
switch (FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_Fw_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_GT46CWM_Liv46;
    1: switch_Couplers_8_Repeat;
}

//Rear Stack
switch (FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_Rw_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_GT46CWM_Liv46_r;
    1: switch_Couplers_8_Repeat;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_pair, position_in_vehid_chain % 2) {
 1: switch_Clyde_GT46CWM_Liv46_Rw_Stack;
  switch_Clyde_GT46CWM_Liv46_Fw_Stack;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_rear, position_in_vehid_chain_from_end) {
 0: switch_Clyde_GT46CWM_Liv46_Rw_Stack;
  switch_Clyde_GT46CWM_Liv46_pair;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_GT46CWM_Liv46_position, position_in_consist) {
 0: switch_Clyde_GT46CWM_Liv46_Fw_Stack;
  switch_Clyde_GT46CWM_Liv46_rear;
}

