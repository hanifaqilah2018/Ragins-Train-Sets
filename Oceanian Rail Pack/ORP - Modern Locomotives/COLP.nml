spriteset(spriteset_Clyde_XClassS1and2_Liv23_r,   "gfx/Clyde_XClass_Liv23.png") {template_8_r(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_XClassS1and2_Liv23_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_XClassS1and2_Liv23;
	1: switch_Couplers_8_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_XClassS1and2_Liv23_r;
	1: switch_Couplers_8_Repeat;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_pair, position_in_vehid_chain % 2) {
 1: switch_Clyde_XClassS1and2_Liv23_r;
  switch_Clyde_XClassS1and2_Liv23_Fw;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_rear, position_in_vehid_chain_from_end) {
 0: switch_Clyde_XClassS1and2_Liv23_r;
  switch_Clyde_XClassS1and2_Liv23_pair;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_XClassS1and2_Liv23_position, position_in_consist) {
 0: switch_Clyde_XClassS1and2_Liv23_Fw;
  switch_Clyde_XClassS1and2_Liv23_rear;
}

const Clyde_G16CS1_Liv23_ID = (Clyde_G16CS1_ID + Liv23_ID);

//Clyde_G16CS1_Liv23
item(FEAT_TRAINS, Item_Clyde_G16CS1_Liv23, Clyde_G16CS1_Liv23_ID) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_DIESEL;
        engine_class:                   ENGINE_CLASS_DIESEL;
//        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		visual_effect_and_powered: 		visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 3, DISABLE_WAGON_POWER);

        name:                           string(STR_NAME_CLYDE_G16CS1);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Clyde_G16CS1_IntroDate;		
		length:                         8;
		
		speed:							Clyde_G16CS1_Speed km/h;
		cost_factor:					Clyde_G16CS1_CostFactor;
		running_cost_factor:			Clyde_G16CS1_RunningCostFactor;
		cargo_capacity: 				0;
		power:							Clyde_G16CS1_Power;
		weight:							Clyde_G16CS1_Weight;
		
        variant_group: 					Item_Clyde_G16CS1_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_Clyde_XClassS1and2_Liv23_position;
//		sound_effect: 					switch_EMD_16_567;
        purchase: 						switch_Clyde_XClassS1and2_Liv23_Purchase_Stack;
        additional_text: 				string(STR_INFO_CLYDE_G16CS1);
		reverse_build_probability: 		return 25;
}
}

