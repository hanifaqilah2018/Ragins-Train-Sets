spriteset(spriteset_Comeng_CL632_3RShoes_Purchase,   "gfx/Comeng_CL632_3RShoes.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Comeng_CL632_3RShoes,   "gfx/Comeng_CL632_3RShoes.png") {template_8_repeat(7, 39)}

//Comeng_CL632_3R_Liv0
//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_2, tile_powers_railtype("OHLE_DC")) {
            1: return 3620;}
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 4290;
                return switch_Comeng_CL632_3R_Liv0_power_2;}
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_0, tile_powers_railtype("SAA3")) {
            1: return 3620;
                return switch_Comeng_CL632_3R_Liv0_power_1;}

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_DC)
                    | (3620 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_AC)
                    | (4290 << 16),
                    0x101
                ),
				STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (3620 << 16),
                    0x102
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_THREE_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_THREE_SOURCES), string(STR_INFO_COMENG_CL632_3R));
        }

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL632_Liv0_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
	2: spriteset_Comeng_CL632_Pantograph_Purchase;
	3: spriteset_Comeng_CL632_3RShoes_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL632_Liv0;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL632_Fw_railtype_AC;
	3: spriteset_Comeng_CL632_3RShoes;
}

switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL632_Liv0;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL632_r_railtype_AC;
	3: spriteset_Comeng_CL632_3RShoes;
