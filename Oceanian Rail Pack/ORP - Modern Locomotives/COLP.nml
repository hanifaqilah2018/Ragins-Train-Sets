const Clyde_A32D_RunningCostFactor = 165;
//power
const Clyde_A32D_Power = 4400;
//weight
const Clyde_A32D_Weight = 230;

//Clyde_A32D_Liv0
spriteset(spriteset_Clyde_A32D_Liv0_Purchase,   "gfx/Clyde_A32D_Liv0.png") {template_purchase_9(7, 21)}

spriteset(spriteset_Clyde_A32D_Liv0,   "gfx/Clyde_A32D_Liv0.png") {template_9(7, 39)}
spriteset(spriteset_Clyde_A32D_Liv0_r,   "gfx/Clyde_A32D_Liv0.png") {template_9_r(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_A32D_Liv0_Purchase;
    1: switch_Couplers_9F_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_A32D_Liv0;
	1: switch_Couplers_9F;
}

switch (FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Clyde_A32D_Liv0_r;
	1: switch_Couplers_9F_r;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_pair, position_in_vehid_chain % 4) {
 0: switch_Clyde_A32D_Liv0_Fw;
 3: switch_Clyde_A32D_Liv0_r;
  switch_Clyde_A32D_Liv0_r;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_rear, position_in_vehid_chain_from_end) {
 1: switch_Clyde_A32D_Liv0_r;
  switch_Clyde_A32D_Liv0_pair;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_direction_position, position_in_consist) {
 0: switch_Clyde_A32D_Liv0_Fw;
  switch_Clyde_A32D_Liv0_rear;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_position, position_in_articulated_veh) {
 0: switch_Clyde_A32D_Liv0_direction_position;
 1: spriteset_8_Blank;
}

switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_length, position_in_vehid_chain % 2) {
 0: 5;
 1: 4;
 }
 
 // Articulated part callback
switch(FEAT_TRAINS, SELF, switch_Clyde_A32D_Liv0_articulated_part, extra_callback_info1) {
    0..1: return Item_Clyde_A32D_Liv0;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

const Clyde_A32D_Liv0_ID = (Clyde_A32D_ID + Liv0_ID);

item(FEAT_TRAINS, Item_Clyde_A32D_Liv0, Clyde_A32D_Liv0_ID) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_DIESEL;
        engine_class:                   ENGINE_CLASS_DIESEL;
//        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_ProposalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		visual_effect_and_powered: 		visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 3, DISABLE_WAGON_POWER);

        name:                           string(STR_NAME_CLYDE_A32D);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Clyde_A32D_IntroDate;		
//		length:                         8;
		
		speed:							Clyde_A32D_Speed km/h;
		cost_factor:					Clyde_A32D_CostFactor;
		running_cost_factor:			Clyde_A32D_RunningCostFactor;
		cargo_capacity: 				0;
		power:							Clyde_A32D_Power;
		weight:							Clyde_A32D_Weight;
		
//        variant_group: 					Item_Clyde_A32D_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_Clyde_A32D_Liv0_position;
//        sound_effect: 				switch_EMD_16_567;
        purchase: 						switch_Clyde_A32D_Liv0_Purchase_Stack;
        additional_text: 				string(STR_INFO_CLYDE_A32D);
        length: 						switch_Clyde_A32D_Liv0_length;
        articulated_part: 				switch_Clyde_A32D_Liv0_articulated_part;        
}
}

