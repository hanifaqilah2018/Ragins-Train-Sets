    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL627A_r_railtype;
	3: spriteset_Comeng_CL627A_3RShoes;
}

switch(FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_position, vehicle_is_flipped) {
 0: switch_Comeng_CL627A_3R_Liv0_Fw;
 1: switch_Comeng_CL627A_3R_Liv0_r;
}

item(FEAT_TRAINS, Item_Comeng_CL627A_3R_Liv0, 59400) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available: (param_RealDisable == 0 && param_ThirdRailDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        track_type:                        [OHLE_DC, SAA3];
        running_cost_base:                RUNNING_COST_DIESEL;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
//        ai_special_flag:                AI_FLAG_CARGO;
        dual_headed:                    0; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_COMENG_CL627A_3R);
        introduction_date:                date(1983,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        119 ton;
        speed:                            130 km/h;
        power:                            3620 hp;
        tractive_effort_coefficient:     0.3;
        cost_factor:                     54;
        running_cost_factor:             146;
		cargo_capacity:                  0;
		
//        variant_group: Item_Comeng_CL627A_3R_Liv0;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: switch_Comeng_CL627A_3R_Liv0_position;
//		sound_effect: switch_Modern_Electric_Horn;
        purchase: switch_Comeng_CL627A_3R_Liv0_Purchase_Stack;
        power: switch_Comeng_CL627A_3R_Liv0_power_0;
        visual_effect_and_powered: switch_Comeng_CL627A_3R_Liv0_effect_spawn_model_and_powered;
        additional_text: switch_Comeng_CL627A_3R_Liv0_buy_menu_additional_text;
		reverse_build_probability: return 50;
}
}

//Comeng_CL627A_3R_Liv0_TriBo
//Change power output based on rail type
switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_power_1, tile_powers_railtype("OHLE_DC")) {
            1: return 3620;
        }
        switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_power_0, tile_powers_railtype("SAA3")) {
            1: return 3620;
                return switch_Comeng_CL627A_3R_Liv0_TriBo_power_1;
        }

//Change effects based on railtype
switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_effect_spawn_model_and_powered, [tile_powers_railtype("SAA3")]) {
            1: return VISUAL_EFFECT_DISABLE;
            return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 3, ENABLE_WAGON_POWER);
        }

//Power Language File Switch
switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_buy_menu_additional_text, [
                STORE_TEMP(
                    string(STR_POWER_SOURCE_OHLE_DC)
                    | (3620 << 16),
                    0x100
                ),
                STORE_TEMP(
                    string(STR_POWER_SOURCE_3RAIL)
                    | (3620 << 16),
                    0x101
                ),
        ]) {
            return string(STR_BUY_MENU_ADDITIONAL_TEXT_WRAPPER_TWO_SUBSTR, string(STR_POWER_BY_POWER_SOURCE_TWO_SOURCES), string(STR_INFO_COMENG_CL627A_3R));
        }

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0_TriBo_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
	2: spriteset_Comeng_CL627A_Pantograph_Purchase;
	3: spriteset_Comeng_CL627A_3RShoes_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0_TriBo;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL627A_Fw_railtype;
	3: spriteset_Comeng_CL627A_3RShoes;
}

switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0_TriBo;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL627A_r_railtype;
	3: spriteset_Comeng_CL627A_3RShoes;
}

switch(FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_position, vehicle_is_flipped) {
 0: switch_Comeng_CL627A_3R_Liv0_TriBo_Fw;
 1: switch_Comeng_CL627A_3R_Liv0_TriBo_r;
