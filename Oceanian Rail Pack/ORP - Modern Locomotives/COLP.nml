    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0_TriBo;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL627A_Fw_railtype;
	3: spriteset_Comeng_CL627A_3RShoes;
}

switch (FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_CL627A_Liv0_TriBo;
	1: switch_Couplers_8_Repeat;
    2: switch_Comeng_CL627A_r_railtype;
	3: spriteset_Comeng_CL627A_3RShoes;
}

switch(FEAT_TRAINS, SELF, switch_Comeng_CL627A_3R_Liv0_TriBo_position, vehicle_is_flipped) {
 0: switch_Comeng_CL627A_3R_Liv0_TriBo_Fw;
 1: switch_Comeng_CL627A_3R_Liv0_TriBo_r;
}

item(FEAT_TRAINS, Item_Comeng_CL627A_3R_Liv0_TriBo, 59500) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available: (param_RealDisable == 0 && param_ThirdRailDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        track_type:                        [OHLE_DC, SAA3];
        running_cost_base:                RUNNING_COST_DIESEL;
        engine_class:                     ENGINE_CLASS_ELECTRIC;
//        ai_special_flag:                AI_FLAG_CARGO;
        dual_headed:                    0; // <- Double Headed, so cab on each end

        visual_effect_and_powered: VISUAL_EFFECT_ELECTRIC;

        name:                            string(STR_NAME_COMENG_CL627A_3R_TRIBO);
        introduction_date:                date(1985,1,1);
        vehicle_life:                     50;
        model_life:                        30;
        length:                            8;

        weight:                        123 ton;
        speed:                            130 km/h;
        power:                            3620 hp;
        tractive_effort_coefficient:     0.3;
        cost_factor:                     16;
        running_cost_factor:             120;
		cargo_capacity:                  0;
		
//        variant_group: Item_Comeng_CL627A_3R_Liv0_TriBo;
//        extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: switch_Comeng_CL627A_3R_Liv0_TriBo_position;
//		sound_effect: switch_Modern_Electric_Horn;
        purchase: switch_Comeng_CL627A_3R_Liv0_TriBo_Purchase_Stack;
        power: switch_Comeng_CL627A_3R_Liv0_TriBo_power_0;
        visual_effect_and_powered: switch_Comeng_CL627A_3R_Liv0_TriBo_effect_spawn_model_and_powered;
        additional_text: switch_Comeng_CL627A_3R_Liv0_TriBo_buy_menu_additional_text;
		reverse_build_probability: return 50;
}
}

//ALCO_C628_Liv0
spriteset(spriteset_ALCO_C628_Liv0_Purchase,   "gfx/ALCO_C628_Liv0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_ALCO_C628_Liv0,   "gfx/ALCO_C628_Liv0.png") {template_8(7, 39)} // <- Define a wagon, in this case the cab
spriteset(spriteset_ALCO_C628_Liv0_r,   "gfx/ALCO_C628_Liv0.png") {template_8_r(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ALCO_C628_Liv0_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_Fw, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ALCO_C628_Liv0;
	1: switch_Couplers_8_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ALCO_C628_Liv0_r;
	1: switch_Couplers_8_Repeat;
}

switch(FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_pair, position_in_vehid_chain % 2) {
 1: switch_ALCO_C628_Liv0_r;
  switch_ALCO_C628_Liv0_Fw;
}

switch(FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_rear, position_in_vehid_chain_from_end) {
 0: switch_ALCO_C628_Liv0_r;
  switch_ALCO_C628_Liv0_pair;
}

switch(FEAT_TRAINS, SELF, switch_ALCO_C628_Liv0_position, position_in_consist) {
 0: switch_ALCO_C628_Liv0_Fw;
  switch_ALCO_C628_Liv0_rear;
}

