switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_2, tile_powers_railtype("OHLE_DC")) {
            1: return 3620;}
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_1, tile_powers_railtype("OHLE_AC")) {
            1: return 4290;
                return switch_Comeng_CL632_3R_Liv0_power_2;}
switch (FEAT_TRAINS, SELF, switch_Comeng_CL632_3R_Liv0_power_0, tile_powers_railtype("SAA3")) {
