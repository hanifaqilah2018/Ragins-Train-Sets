//Gen5B_GoodsVan_Liv3
spriteset(spriteset_Gen5B_GoodsVan_Liv3_Purchase,   "gfx/Gen5B_GoodsVan_Liv3_0.png") {template_purchase_9(7, 21)}

spriteset(spriteset_Gen5B_GoodsVan_Liv3_0,   "gfx/Gen5B_GoodsVan_Liv3_0.png") {template_9_repeat(7, 39)}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv3_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv3_Purchase;
    1: switch_Couplers_9_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv3_SpriteStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv3_0;
    1: switch_Couplers_9_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv3_RearStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv3_0;
    1: switch_Couplers_9_Repeat;
	2: spriteset_9_Modern_EOTD;
}

switch(FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv3_rearcheck, position_in_consist_from_end){
