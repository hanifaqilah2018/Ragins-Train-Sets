    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_Flatcar_Liv3_Purchase;
	1: spriteset_Gen4A_Flatcar_Liv3_0_Bulkheads_Purchase;
    2: switch_Couplers_8_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_Bulkheadcar_Liv3_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 5 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_Flatcar_Liv3_0;
	1: switch_Couplers_8_Repeat;
	2: spriteset_Gen4A_Flatcar_Liv3_0_Bulkheads_rear;
    3: switch_Flatbed_8_cargo_type;
	4: spriteset_Gen4A_Flatcar_Liv3_0_Bulkheads_front;
}

