switch (FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen2A_GoodsVan_Liv0_Purchase;
	1: switch_Couplers_5_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_NormalStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen2A_GoodsVan_Liv0_0;
	1: switch_Couplers_5_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_SpriteStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen2A_GoodsVan_Liv0_0;
	1: switch_Couplers_5_Repeat;
    2: spriteset_5_Old_EOTD;
}

switch(FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen2A_GoodsVan_Liv0_SpriteStack1;
    return switch_Gen2A_GoodsVan_Liv0_NormalStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_SpriteStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen2A_GoodsVan_Liv0_0;
	1: switch_Couplers_5_Repeat;
    2: spriteset_5_Old_EOTD_r;
}

switch(FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen2A_GoodsVan_Liv0_SpriteStack2;
    return switch_Gen2A_GoodsVan_Liv0_NormalStack;
}

switch(FEAT_TRAINS, SELF, switch_Gen2A_GoodsVan_Liv0_position, vehicle_is_flipped) {
 0: switch_Gen2A_GoodsVan_Liv0_rearcheck1;
 1: switch_Gen2A_GoodsVan_Liv0_rearcheck2;
}

item (FEAT_TRAINS, Item_Gen2A_GoodsVan_Liv0_NG, 30550) {
    property {
		sprite_id:                        SPRITE_ID_NEW_TRAIN;
		misc_flags:                        bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK, TRAIN_FLAG_AUTOREFIT);
		track_type:                        NG_RAIL_ONLY;
		ai_special_flag:                AI_FLAG_CARGO;
		bitmask_vehicle_info:            0;
	
		climates_available:             ALL_CLIMATES;
        refittable_cargo_classes:		bitmask( CC_MAIL, CC_POTABLE, CC_PIECE_GOODS, CC_COVERED_BULK, CC_POWDER_BULK, CC_LIQUID_BULK, CC_GAS_BULK, CC_EXPRESS, CC_ARMOURED ); //GoodsVan
		non_refittable_cargo_classes:		bitmask(CC_PASSENGERS); //GoodsVan
		default_cargo_type:				GOOD; //GoodsVan
//		cargo_allow_refit:				[GRAI, WHEA, BEAN, SGCN, SGBT, OLSD, MAIZ, PEAT, SEED]; //GoodsVan
		cargo_disallow_refit:			[TOUR, LVST]; //GoodsVan

        name:                             string(STR_NAME_GEN2A_GOODSVAN_NG);

        refit_cost:                        0;
        power:                            0 hp;
        dual_headed:                    0;
        air_drag_coefficient:            0.08;
