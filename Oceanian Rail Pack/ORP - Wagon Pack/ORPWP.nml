item (FEAT_TRAINS, Item_Gen4A_Stakecar_Liv0_NG, Gen4A_Stakecar_ID_Liv0_NG) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK, TRAIN_FLAG_AUTOREFIT);
		track_type:                     NG_RAIL_ONLY;
		running_cost_base:              RUNNING_COST_STEAM;
//        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             ALL_CLIMATES;
		refittable_cargo_classes: 		bitmask(CC_FLATBED); //Stakecar
		non_refittable_cargo_classes: 	bitmask(); //Stakecar
		default_cargo_type:				GOOD; //Stakecar
		cargo_allow_refit: 				[METL,PIPE,STEL,WDPR,WOOD]; //Stakecar
		cargo_disallow_refit:			[TOUR, LVST]; //Stakecar

        name:                           string(STR_NAME_GEN4A_STAKECAR_NG);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		
        introduction_date:              Gen4A_Stakecar_IntroDate;		
		length:                         8;
		
		loading_speed:					Gen4_LoadingSpeed;
		speed:							Gen4_Speed km/h;
