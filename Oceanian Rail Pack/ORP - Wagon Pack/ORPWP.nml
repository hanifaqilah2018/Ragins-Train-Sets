spriteset(spriteset_Gen3A_GoodsVan_Liv0_Purchase,   "gfx/Gen3A_GoodsVan_Liv0_0.png") {template_purchase_6(7, 21)}

spriteset(spriteset_Gen3A_GoodsVan_Liv0_0,   "gfx/Gen3A_GoodsVan_Liv0_0.png") {template_6_repeat(7, 39)}

switch (FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen3A_GoodsVan_Liv0_Purchase;
	1: switch_Couplers_6_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_NormalStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen3A_GoodsVan_Liv0_0;
	1: switch_Couplers_6_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_SpriteStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen3A_GoodsVan_Liv0_0;
	1: switch_Couplers_6_Repeat;
    2: spriteset_6_Old_EOTD;
}

switch(FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen3A_GoodsVan_Liv0_SpriteStack1;
    return switch_Gen3A_GoodsVan_Liv0_NormalStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_SpriteStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen3A_GoodsVan_Liv0_0;
	1: switch_Couplers_6_Repeat;
    2: spriteset_6_Old_EOTD_r;
}

switch(FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen3A_GoodsVan_Liv0_SpriteStack2;
    return switch_Gen3A_GoodsVan_Liv0_NormalStack;
}

switch(FEAT_TRAINS, SELF, switch_Gen3A_GoodsVan_Liv0_position, vehicle_is_flipped) {
 0: switch_Gen3A_GoodsVan_Liv0_rearcheck1;
 1: switch_Gen3A_GoodsVan_Liv0_rearcheck2;
}

