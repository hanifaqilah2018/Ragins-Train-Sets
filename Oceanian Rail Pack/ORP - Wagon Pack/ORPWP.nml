//Gen5B_GoodsVan_Liv2
spriteset(spriteset_Gen5B_GoodsVan_Liv2_Purchase,   "gfx/Gen5B_GoodsVan_Liv2_0.png") {template_purchase_9(7, 21)}

spriteset(spriteset_Gen5B_GoodsVan_Liv2_0,   "gfx/Gen5B_GoodsVan_Liv2_0.png") {template_9_repeat(7, 39)}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv2_Purchase;
    1: switch_Couplers_9_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_SpriteStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv2_0;
    1: switch_Couplers_9_Repeat;
}

switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_RearStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv2_0;
    1: switch_Couplers_9_Repeat;
	2: spriteset_9_Modern_EOTD;
}

switch(FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_rearcheck, position_in_consist_from_end){
    0 : switch_Gen5B_GoodsVan_Liv2_SpriteStack;
	1 : switch_Gen5B_GoodsVan_Liv2_RearStack;
    return switch_Gen5B_GoodsVan_Liv2_SpriteStack;
}

switch(FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_position, position_in_articulated_veh) {
 0: switch_Gen5B_GoodsVan_Liv2_rearcheck;
 1: spriteset_8_Blank;
}

switch(FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_length, position_in_vehid_chain % 2) {
 0: 5;
 1: 4;
 }

// Articulated part callback
switch(FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv2_articulated_part, extra_callback_info1) {
    0..1: return Item_Gen5B_GoodsVan_Liv2;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

