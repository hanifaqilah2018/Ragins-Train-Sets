//6 Long Couplers repeat
spriteset(spriteset_Knuckles_6_Repeat_Purchase,   "gfx/Couplers_6_Repeat.png") {template_purchase_6(7, 21)}
spriteset(spriteset_Knuckles_6_Repeat,   "gfx/Couplers_6_Repeat.png") {template_6_repeat(7, 39)}

spriteset(spriteset_Buffers_6_Repeat_Purchase,   "gfx/Couplers_6_Repeat.png") {template_purchase_6(187, 21)}
spriteset(spriteset_Buffers_6_Repeat,   "gfx/Couplers_6_Repeat.png") {template_6_repeat(187, 39)}

switch(FEAT_TRAINS, PARENT, switch_Couplers_6_Repeat_Purchase_Transition, current_year) {
    0..1945: spriteset_Buffers_6_Repeat_Purchase;
	1945..2100: spriteset_Knuckles_6_Repeat_Purchase;
  return spriteset_Knuckles_6_Repeat_Purchase;
}

