//OpenCars
//ID
const Gen4A_OpenCar_ID = 41150;
//introduction_date
const Gen4A_OpenCar_IntroDate = date(1950, 1, 1);
//weight
const Gen4A_OpenCar_Weight = 20;
//Base
spriteset(spriteset_Gen4A_OpenCar_Base_Purchase,   "gfx/Gen4A_OpenCar_Base.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Gen4A_OpenCar_Base,   "gfx/Gen4A_OpenCar_Base.png") {template_8_repeat(7, 39)}

spriteset(spriteset_Gen4A_OpenCar_Loadh,   "gfx/Gen4A_OpenCar_Load.png") {template_8_repeat(7, 39)}
spriteset(spriteset_Gen4A_OpenCar_Loadf,   "gfx/Gen4A_OpenCar_Load.png") {template_8_repeat(7, 69)}

spriteset(spriteset_Gen4A_OpenCar_Tarp1,   "gfx/Gen4A_OpenCar_Tarp.png") {template_8_repeat(7, 39)}
spriteset(spriteset_Gen4A_OpenCar_Tarp2,   "gfx/Gen4A_OpenCar_Tarp.png") {template_8_repeat(7, 69)}
spriteset(spriteset_Gen4A_OpenCar_Tarp3,   "gfx/Gen4A_OpenCar_Tarp.png") {template_8_repeat(7, 99)}

switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_loadcheck, cargo_count * (100 / cargo_capacity)){
	1..50	: spriteset_Gen4A_OpenCar_Loadh ;
	51..100	: spriteset_Gen4A_OpenCar_Loadf ;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_recolour_load, STORE_TEMP(CB_FLAG_MORE_SPRITES | switch_generic_recolour(), 0x100)) {
    return switch_Gen4A_OpenCar_loadcheck;
}

 random_switch(FEAT_TRAINS, SELF, switch_spriteset_Gen4A_OpenCar_Tarp_Random){
    1 : spriteset_Gen4A_OpenCar_Tarp1;
	1 : spriteset_Gen4A_OpenCar_Tarp2;
	1 : spriteset_Gen4A_OpenCar_Tarp3;
}

//Cargo switch
switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_cargo_class, cargo_classes) {
	//Old
	bitmask(CC_PIECE_GOODS): switch_Flatbed_8_cargo_type;
	
	//FRAX
	bitmask(CC_FLATBED): switch_Flatbed_8_cargo_type;
	
	//Fallback
	switch_Gen4A_OpenCar_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Tarp_Check, cargo_type_in_veh) {
	GRAI: switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	//Fallback
	switch_Gen4A_OpenCar_recolour_load;
}

//Cargo switch
switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_tarp_cargo_class, cargo_classes) {
	//check cargo first, then tarp
	bitmask(CC_BULK): switch_Gen4A_OpenCar_Tarp_Check;
	//Put tarp
	bitmask(CC_BULK, CC_COVERED): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_COVERED): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	
	//FRAX
	//If used above, blank sprite
	bitmask(CC_PIECE_GOODS): spriteset_8_Blank;
	bitmask(CC_FLATBED): spriteset_8_Blank;
	//check cargo first, then tarp
	bitmask(CC_OPEN_BULK): switch_Gen4A_OpenCar_recolour_load;
	//Put tarp
	bitmask(CC_POTABLE): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_COVERED_BULK): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_POWDER_BULK): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_LIQUID_BULK): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_GAS_BULK): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_EXPRESS): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	bitmask(CC_WEIRD): switch_spriteset_Gen4A_OpenCar_Tarp_Random;
	
	//Fallback
	switch_spriteset_Gen4A_OpenCar_Tarp_Random;
}

//Gen4A_OpenCar_Liv0
spriteset(spriteset_Gen4A_OpenCar_Liv0_Purchase,   "gfx/Gen4A_OpenCar_Liv0_0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Gen4A_OpenCar_Liv0_0_BaseR,   "gfx/Gen4A_OpenCar_Liv0_0.png") {template_8_repeat(7, 39)}
spriteset(spriteset_Gen4A_OpenCar_Liv0_0_BaseF,   "gfx/Gen4A_OpenCar_Liv0_0.png") {template_8_repeat(96, 39)}

switch (FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_OpenCar_Base_Purchase;
	1: spriteset_Gen4A_OpenCar_Liv0_Purchase;
    2: switch_Couplers_8_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 6 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_OpenCar_Base;
	1: spriteset_Gen4A_OpenCar_Liv0_0_BaseR;
	2: switch_Gen4A_OpenCar_cargo_class;
    3: spriteset_Gen4A_OpenCar_Liv0_0_BaseF;
	4: switch_Couplers_8_Repeat;
	5: switch_Gen4A_OpenCar_tarp_cargo_class;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 7 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_OpenCar_Base;
	1: spriteset_Gen4A_OpenCar_Liv0_0_BaseR;
	2: switch_Gen4A_OpenCar_cargo_class;
	3: spriteset_Gen4A_OpenCar_Liv0_0_BaseF;
    4: switch_Couplers_8_Repeat;
	5: switch_Gen4A_OpenCar_tarp_cargo_class; 
	6: spriteset_8_Modern_EOTD;
}

switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen4A_OpenCar_Liv0_RearStack1;
    return switch_Gen4A_OpenCar_Liv0_CargoStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_RearStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 7 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_OpenCar_Base;
	1: spriteset_Gen4A_OpenCar_Liv0_0_BaseR;
	2: switch_Gen4A_OpenCar_cargo_class;
	3: spriteset_Gen4A_OpenCar_Liv0_0_BaseF;
    4: switch_Couplers_8_Repeat;
	5: switch_Gen4A_OpenCar_tarp_cargo_class; 
	6: spriteset_8_Modern_EOTD_r;
}

switch(FEAT_TRAINS, SELF, switch_Gen4A_OpenCar_Liv0_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen4A_OpenCar_Liv0_RearStack2;
    return switch_Gen4A_OpenCar_Liv0_CargoStack;
}

