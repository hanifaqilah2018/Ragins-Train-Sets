switch (FEAT_TRAINS, SELF, switch_Gen5B_GoodsVan_Liv1_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5B_GoodsVan_Liv1_Purchase;
    1: switch_Couplers_9_Repeat_Purchase;
