spriteset(spriteset_Gen4D_OpenHopper_Loadh,   "gfx/Gen4D_OpenHopper_Load.png") {template_6_repeat(7, 39)}
spriteset(spriteset_Gen4D_OpenHopper_Loadf,   "gfx/Gen4D_OpenHopper_Load.png") {template_6_repeat(7, 69)}

switch(FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_loadcheck, cargo_count * (100 / cargo_capacity)){
	1..50	: spriteset_Gen4D_OpenHopper_Loadh ;
	51..100	: spriteset_Gen4D_OpenHopper_Loadf ;
}

switch (FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_recolour_load, STORE_TEMP(switch_generic_recolour(), 0x100)) {
    return switch_Gen4D_OpenHopper_loadcheck;
}

//Gen4D_OpenHopper_Liv0
spriteset(spriteset_Gen4D_OpenHopper_Liv0_Purchase,   "gfx/Gen4D_OpenHopper_Liv0_0.png") {template_purchase_6(7, 21)}

spriteset(spriteset_Gen4D_OpenHopper_Liv0_0,   "gfx/Gen4D_OpenHopper_Liv0_0.png") {template_6_repeat(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4D_OpenHopper_Liv0_Purchase;
    1: switch_Couplers_6_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4D_OpenHopper_Liv0_0;
	1: switch_Couplers_6_Repeat;
    2: switch_Gen4D_OpenHopper_recolour_load;
}

switch (FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4D_OpenHopper_Liv0_0;
	1: switch_Couplers_6_Repeat;
	2: spriteset_6_Old_EOTD;
    3: switch_Gen4D_OpenHopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen4D_OpenHopper_Liv0_RearStack1;
    return switch_Gen4D_OpenHopper_Liv0_CargoStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_RearStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4D_OpenHopper_Liv0_0;
	1: switch_Couplers_6_Repeat;
	2: spriteset_6_Old_EOTD_r;
    3: switch_Gen4D_OpenHopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen4D_OpenHopper_Liv0_RearStack2;
    return switch_Gen4D_OpenHopper_Liv0_CargoStack;
}

switch(FEAT_TRAINS, SELF, switch_Gen4D_OpenHopper_Liv0_position, vehicle_is_flipped) {
 0: switch_Gen4D_OpenHopper_Liv0_rearcheck1;
 1: switch_Gen4D_OpenHopper_Liv0_rearcheck2;
}

item (FEAT_TRAINS, Item_Gen4D_OpenHopper_Liv0_NG, 42150) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
		misc_flags:                        bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK, TRAIN_FLAG_AUTOREFIT);
		track_type:                        NG_RAIL_ONLY;
		ai_special_flag:                AI_FLAG_CARGO;
		bitmask_vehicle_info:            0;
	
		climates_available:             ALL_CLIMATES;
		refittable_cargo_classes:		bitmask(CC_BULK); //OpenHopper
		non_refittable_cargo_classes:		bitmask(CC_PASSENGERS, CC_COVERED_BULK, CC_POTABLE, CC_HAZARDOUS); //OpenHopper
		default_cargo_type:				COAL; //OpenHopper
//		cargo_allow_refit:				[GRAI, WHEA, BEAN, SGCN, SGBT, OLSD, MAIZ, PEAT, SEED]; //OpenHopper
		cargo_disallow_refit:			[TOUR, LVST, MAIZ, GRAI, WHEA, CERE, BEAN, CASS, SGBT, CTCD, TOFF]; //OpenHopper

        name:                             string(STR_NAME_GEN4D_OPENHOPPER_NG);

        refit_cost:                        0;
        power:                            0 hp;
        dual_headed:                    0;
        air_drag_coefficient:            0.08;
        running_cost_base:                RUNNING_COST_STEAM;
        model_life:                        30;
		
        introduction_date:              date(1950, 1, 1);		
		length:                         6;
		weight:                         20 ton;
		
		loading_speed:					1;
		speed:							1;
		cost_factor:					1;
		running_cost_factor:			1;
		cargo_capacity: 				1;
		
		//variant_group: Item_Gen4D_OpenHopper_Liv0_NG;
		//extra_flags:  bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
	}
    graphics {
    default:                             switch_Gen4D_OpenHopper_Liv0_position;
    purchase:                            switch_Gen4D_OpenHopper_Liv0_PurchaseStack;
    additional_text: string(STR_INFO_GEN4D_OPENHOPPER_NG);
	loading_speed:					  return Gen4_LoadingSpeed;
	speed:							  return Gen4_Speed;
	cost_factor:					  return Gen4_6_CostFactor;
	running_cost_factor:			  return Gen4_6_RunningCostFactor;
	cargo_capacity:                   return Gen4_6_CargoCapacity;
}
}


