//Gen4E_OpenHopper_Liv1
spriteset(spriteset_Gen4E_OpenHopper_Liv1_Purchase,   "gfx/Gen4E_OpenHopper_Liv1_0.png") {template_purchase_6(7, 21)}

spriteset(spriteset_Gen4E_OpenHopper_Liv1_0,   "gfx/Gen4E_OpenHopper_Liv1_0.png") {template_6_repeat(7, 39)}
spriteset(spriteset_Gen4E_OpenHopper_Liv1_1,   "gfx/Gen4E_OpenHopper_Liv1_1.png") {template_6_repeat(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4E_OpenHopper_Liv1_Purchase;
    1: switch_Couplers_6_Repeat_Purchase;
}

 random_switch(FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_Random){
    1 : spriteset_Gen4E_OpenHopper_Liv1_0;
	1 : spriteset_Gen4E_OpenHopper_Liv1_1;
}

switch (FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen4E_OpenHopper_Liv1_Random;
	1: switch_Couplers_6_Repeat;
    2: switch_Gen4E_OpenHopper_recolour_load;
}

switch (FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: switch_Gen4E_OpenHopper_Liv1_Random;
	1: switch_Couplers_6_Repeat;
	2: spriteset_6_Old_EOTD;
    3: switch_Gen4E_OpenHopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen4E_OpenHopper_Liv1_RearStack1;
    return switch_Gen4E_OpenHopper_Liv1_CargoStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen4E_OpenHopper_Liv1_RearStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
