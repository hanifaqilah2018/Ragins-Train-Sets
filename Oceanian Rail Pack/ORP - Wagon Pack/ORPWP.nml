//Gen4A_Flatcar_Liv4
spriteset(spriteset_Gen4A_Flatcar_Liv4_Purchase,   "gfx/Gen4A_Flatcar_Liv4_0.png") {template_purchase_8(7, 21)}
spriteset(spriteset_Gen4A_Flatcar_Liv4_0,   "gfx/Gen4A_Flatcar_Liv4_0.png") {template_8_repeat(7, 39)}

switch (FEAT_TRAINS, SELF, switch_Gen4A_Flatcar_Liv4_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_Flatcar_Liv4_Purchase;
    1: switch_Couplers_8_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_Flatcar_Liv4_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_Flatcar_Liv4_0;
	1: switch_Couplers_8_Repeat;
    2: switch_Flatbed_8_cargo_type;
}

switch (FEAT_TRAINS, SELF, switch_Gen4A_Flatcar_Liv4_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 4 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen4A_Flatcar_Liv4_0;
	1: switch_Couplers_8_Repeat;
	2: spriteset_8_Modern_EOTD;
    3: switch_Flatbed_8_cargo_type;
}

