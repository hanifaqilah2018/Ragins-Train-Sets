//Gen5H_OpenHopper_Liv1
spriteset(spriteset_Gen5H_OpenHopper_Liv1_Purchase,   "gfx/Gen5H_OpenHopper_Liv1_0.png") {template_purchase_7(7, 21)}

spriteset(spriteset_Gen5H_OpenHopper_Liv1_0,   "gfx/Gen5H_OpenHopper_Liv1_0.png") {template_7_repeat(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5H_OpenHopper_Liv1_Purchase;
    1: switch_Couplers_7_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_CargoStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5H_OpenHopper_Liv1_0;
	1: switch_Couplers_7_Repeat;
    2: switch_Gen5H_OpenHopper_recolour_load;
}

switch (FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_RearStack1, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5H_OpenHopper_Liv1_0;
	1: switch_Couplers_7_Repeat;
	2: spriteset_7_Modern_EOTD;
    3: switch_Gen5H_OpenHopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_rearcheck1, position_in_consist_from_end){
    0 : switch_Gen5H_OpenHopper_Liv1_RearStack1;
    return switch_Gen5H_OpenHopper_Liv1_CargoStack;
}

switch (FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_RearStack2, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Gen5H_OpenHopper_Liv1_0;
	1: switch_Couplers_7_Repeat;
	2: spriteset_7_Modern_EOTD_r;
    3: switch_Gen5H_OpenHopper_recolour_load;
}

switch(FEAT_TRAINS, SELF, switch_Gen5H_OpenHopper_Liv1_rearcheck2, position_in_consist_from_end){
    0 : switch_Gen5H_OpenHopper_Liv1_RearStack2;
