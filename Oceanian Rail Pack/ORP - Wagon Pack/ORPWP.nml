switch(FEAT_TRAINS, SELF, switch_Gen4A_Bulkheadcar_Liv3_position, vehicle_is_flipped) {
 0: switch_Gen4A_Bulkheadcar_Liv3_rearcheck1;
 1: switch_Gen4A_Bulkheadcar_Liv3_rearcheck2;
}

const Gen4A_Bulkheadcar_ID_Liv3_NG = (Gen4A_Bulkheadcar_ID + Liv3_ID);

item (FEAT_TRAINS, Item_Gen4A_Bulkheadcar_Liv3_NG, Gen4A_Bulkheadcar_ID_Liv3_NG) {
    property {
		sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK, TRAIN_FLAG_AUTOREFIT);
		track_type:                     NG_RAIL_ONLY;
		running_cost_base:              RUNNING_COST_STEAM;
//        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             ALL_CLIMATES;
		refittable_cargo_classes: 		bitmask(CC_FLATBED); //Bulkheadcar
		non_refittable_cargo_classes: 	bitmask(); //Bulkheadcar
		default_cargo_type:				GOOD; //Bulkheadcar
		cargo_allow_refit: 				[METL,PIPE,STEL,WDPR,WOOD]; //Bulkheadcar
		cargo_disallow_refit:			[TOUR, LVST]; //Bulkheadcar

        name:                           string(STR_NAME_GEN4A_BULKHEADCAR_NG);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		
        introduction_date:              Gen4A_Bulkheadcar_IntroDate;		
		length:                         8;
		
		loading_speed:					Gen4_LoadingSpeed;
		speed:							Gen4_Speed km/h;
		cost_factor:					Gen4_8_CostFactor;
		running_cost_factor:			Gen4_8_RunningCostFactor;
		cargo_capacity: 				(Gen4_8_CargoCapacity / param_freight_capacity_mod);
		weight:							Gen4A_Bulkheadcar_Weight ton;

        variant_group: 					Item_Gen4A_Bulkheadcar_Liv0_NG;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
	}
    graphics {
    default:                             switch_Gen4A_Bulkheadcar_Liv3_position;
    purchase:                            switch_Gen4A_Bulkheadcar_Liv3_PurchaseStack;
    additional_text: 					 string(STR_INFO_GEN4A_BULKHEADCAR_NG);
}
}

