spriteset(spriteset_NSW_N67_Jackshaft1,   "gfx/NSW_N67_Jackshaft1.png") {template_5(7, 39)}
spriteset(spriteset_NSW_N67_Jackshaft2,   "gfx/NSW_N67_Jackshaft2.png") {template_5(7, 39)}
spriteset(spriteset_NSW_N67_Jackshaft3,   "gfx/NSW_N67_Jackshaft3.png") {template_5(7, 39)}
spriteset(spriteset_NSW_N67_Jackshaft4,   "gfx/NSW_N67_Jackshaft4.png") {template_5(7, 39)}

switch(FEAT_TRAINS, SELF, switch_NSW_N67_Animation, motion_counter % 4){
    0: spriteset_NSW_N67_Jackshaft1;
    1: spriteset_NSW_N67_Jackshaft2;
    2: spriteset_NSW_N67_Jackshaft3;
    3: spriteset_NSW_N67_Jackshaft4;
    spriteset_NSW_N67_Jackshaft1;
}

switch(FEAT_TRAINS, SELF, switch_NSW_N67_Animation_r, motion_counter % 4){
    0: spriteset_NSW_N67_Jackshaft4;
    1: spriteset_NSW_N67_Jackshaft3;
    2: spriteset_NSW_N67_Jackshaft2;
    3: spriteset_NSW_N67_Jackshaft1;
    spriteset_NSW_N67_Jackshaft4;
}

switch(FEAT_TRAINS, SELF, switch_NSW_N67_AnimDirection, vehicle_is_flipped) {
 0: switch_NSW_N67_Animation;
 1: switch_NSW_N67_Animation_r;
}

//NSW_N67_Liv0
spriteset(spriteset_NSW_N67_Liv0_Purchase,   "gfx/NSW_N67_Liv0.png") {template_purchase_5(7, 21)}
spriteset(spriteset_NSW_N67_Liv0,   "gfx/NSW_N67_Liv0.png") {template_5(7, 39)}

//Purchase Sprite Stacker
switch (FEAT_TRAINS, SELF, switch_NSW_N67_Liv0_Purchase_Stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_NSW_N67_Liv0_Purchase;
    1: switch_Couplers_5_Repeat_Purchase;
}

switch (FEAT_TRAINS, SELF, switch_NSW_N67_Liv0, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_NSW_N67_Liv0;
	1: switch_Couplers_5_Repeat;
    2: switch_NSW_N67_AnimDirection;
}

const NSW_N67_Liv0_ID = (NSW_N67_ID + Liv0_ID);

item(FEAT_TRAINS, Item_NSW_N67_Liv0, NSW_N67_Liv0_ID) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_DIESEL;
        engine_class:                   ENGINE_CLASS_STEAM;
//        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		visual_effect_and_powered: 		visual_effect_and_powered(VISUAL_EFFECT_STEAM, 1, DISABLE_WAGON_POWER);

        name:                           string(STR_NAME_NSW_N67);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
