item(FEAT_TRAINS, Item_Goninan_4D_Liv0, Goninan_4D_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_PrototypeDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_GONINAN_4D);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Goninan_4D_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Goninan_4D_Speed km/h;
		cost_factor:					(Goninan_4D_CostFactor * 2);
		running_cost_factor:			(Goninan_4D_RunningCostFactor * 2);
		cargo_capacity: 				(Goninan_4D_CargoCapacity / param_capacity_mod);
		power:							(Goninan_4D_Power * 2);
		weight:							Goninan_4D_Weight ton;

//        variant_group: 					Item_Goninan_4D_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Goninan_4D_Liv0_frontcheck;
        purchase: 						switch_Goninan_4D_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_GONINAN_4D);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_Goninan_4D_Liv0_lencheck ;
        length:							8;
        cargo_capacity:                 [Goninan_4D_CargoCapacity / param_capacity_mod];
        power:                          Goninan_4D_Power;
		weight:                        	Goninan_4D_Weight;
		running_cost_factor:            Goninan_4D_RunningCostFactor;

    }
}

//ID
const TaitInterurban_ID = 13020;
//introduction_date
const TaitInterurban_IntroDate = date(1922, 1, 1);
//speed
const TaitInterurban_Speed = 115;
//cost_factor
const TaitInterurban_CostFactor = 22;
//running_cost_factor
const TaitInterurban_RunningCostFactor = 58;
//Cargo Capacity
const TaitInterurban_CargoCapacity = 71;
//power
const TaitInterurban_Power = 282;
//weight
const TaitInterurban_Weight = 35;
//Length
const TaitInterurban_Length = 8;

//Pantographs
spriteset(spriteset_TaitInterurban_Panto_Purchase,   "gfx/TaitInterurban_Pantographs.png") {template_purchase_88mu(7, 21)}

spriteset(spriteset_TaitInterurban_PantoDown,   "gfx/TaitInterurban_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_TaitInterurban_PantoDown_r,   "gfx/TaitInterurban_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_TaitInterurban_PantoUp,   "gfx/TaitInterurban_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_TaitInterurban_PantoUp_r,   "gfx/TaitInterurban_Pantographs.png") {template_8_r(7, 69)}

spriteset(spriteset_TaitInterurban_Roof1_Purchase,   "gfx/TaitInterurban_Roof1.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_TaitInterurban_Roof1_Motor,   "gfx/TaitInterurban_Roof1.png") {template_8(7, 39)}
spriteset(spriteset_TaitInterurban_Roof1_Motor_r,   "gfx/TaitInterurban_Roof1.png") {template_8_r(7, 39)}
spriteset(spriteset_TaitInterurban_Roof1_Trailer,   "gfx/TaitInterurban_Roof1.png") {template_8_repeat(7, 69)}


spriteset(spriteset_TaitInterurban_Roof2_Purchase,   "gfx/TaitInterurban_Roof2.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_TaitInterurban_Roof2_Motor,   "gfx/TaitInterurban_Roof2.png") {template_8(7, 39)}
spriteset(spriteset_TaitInterurban_Roof2_Motor_r,   "gfx/TaitInterurban_Roof2.png") {template_8_r(7, 39)}
spriteset(spriteset_TaitInterurban_Roof2_Trailer,   "gfx/TaitInterurban_Roof2.png") {template_8_repeat(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_TaitInterurban_Fw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_TaitInterurban_PantoDown;
 1: spriteset_TaitInterurban_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_TaitInterurban_Rw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_TaitInterurban_PantoDown_r; //might need switching back to just panto down
 1: spriteset_TaitInterurban_PantoUp_r;
}
//Roof Controls
//Purchase
switch(FEAT_TRAINS, PARENT, switch_TaitInterurban_Roof_Transition_Purchase, date_of_last_service) {
    0..date(1928, 12, 31): spriteset_TaitInterurban_Roof1_Purchase;
	date(1929, 1, 1)..date(2100, 1, 1): spriteset_TaitInterurban_Roof2_Purchase;
  return spriteset_TaitInterurban_Roof2_Purchase;
}

//Motor Forward
random_switch(FEAT_TRAINS, SELF, switch_TaitInterurban_Roof_Transition_Motor_Random){
    3 : spriteset_TaitInterurban_Roof1_Motor;
	1 : spriteset_TaitInterurban_Roof2_Motor;
}

switch(FEAT_TRAINS, PARENT, switch_TaitInterurban_Roof_Transition_Motor, date_of_last_service) {
    0..date(1928, 12, 31): spriteset_TaitInterurban_Roof1_Motor;
	date(1929, 1, 1)..date(2100, 1, 1): switch_TaitInterurban_Roof_Transition_Motor_Random;
  return switch_TaitInterurban_Roof_Transition_Motor_Random;
}

