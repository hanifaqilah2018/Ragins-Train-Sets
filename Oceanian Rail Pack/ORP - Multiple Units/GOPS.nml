switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: switch_Tait_Liv0_MotorStack; //Panto
    return switch_Tait_Liv0_DrivingTrailerStack; //No Panto
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : sw_Tait_Liv0_panto_direction_r_pos;        //Front panto
    return switch_Tait_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : sw_Tait_Liv0_panto_direction_r;        //Not flipped, give Panto
    return switch_Tait_Liv0_MotorStack_r;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_frontcheck_r, position_in_vehid_chain){
    0: sw_Tait_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return sw_Tait_Liv0_panto_flipcheck_r; //More Checks
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Tait_Liv0_MotorStack;        //Front panto
    return switch_Tait_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Tait_Liv0_panto_direction;        //Not flipped, give Panto
    return switch_Tait_Liv0_DrivingTrailerStack;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Tait_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_Tait_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, sw_Tait_Liv0_directioncheck, vehicle_is_reversed){
    0: sw_Tait_Liv0_frontcheck; //We are going forwards
    return sw_Tait_Liv0_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_Tait_Liv0_revcheck, vehicle_is_reversed){
    0 : sw_Tait_Liv0_lencheck;
    return sw_Tait_Liv0_lencheck_r;
}

const Tait_ID_Liv0 = (Tait_ID_Single_Liv0 + 10);

item(FEAT_TRAINS, Item_Tait_Liv0, Tait_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TAIT_MU);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Tait_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Tait_Speed km/h;
		cost_factor:					(Tait_CostFactor * 2);
		running_cost_factor:			(Tait_RunningCostFactor * 2);
		cargo_capacity: 				(Tait_CargoCapacity / param_capacity_mod);
		power:							(Tait_Power * 2);
		weight:							Tait_Weight ton;

//        variant_group: 					Item_Tait_MU_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Tait_Liv0_directioncheck;
        purchase: 						switch_Tait_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_TAIT_MU);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_Tait_Liv0_revcheck ;
        length:							8;
        cargo_capacity:                 [Tait_CargoCapacity / param_capacity_mod];
        power:                          Tait_Power;
		weight:                        	Tait_Weight;
		running_cost_factor:            Tait_RunningCostFactor;

    }
}

