}
switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Goninan_Tangara_Liv0_NonControlMotorStack;
    return spriteset_Goninan_Tangara_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Goninan_Tangara_Liv0_NonControlMotorStack_r;
    return spriteset_Goninan_Tangara_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Goninan_Tangara_Liv0_NonControlMotorStack;
    return spriteset_Goninan_Tangara_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Goninan_Tangara_Liv0_pantocheck_at_1;
    return sw_Goninan_Tangara_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Goninan_Tangara_Liv0_pantocheck_at_1;
