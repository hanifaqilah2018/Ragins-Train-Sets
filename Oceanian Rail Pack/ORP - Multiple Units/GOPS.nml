const TaitInterurban_ID_Liv1 = (TaitInterurban_ID + Liv1_ID);

item(FEAT_TRAINS, Item_TaitInterurban_Liv1, TaitInterurban_ID_Liv1) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_FictionalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TAITINTERURBAN);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              TaitInterurban_IntroDate;		
		length:                         TaitInterurban_Length;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							TaitInterurban_Speed km/h;
		cost_factor:					(TaitInterurban_CostFactor * 2);
		running_cost_factor:			(TaitInterurban_RunningCostFactor * 2);
		cargo_capacity: 				(TaitInterurban_CargoCapacity / param_capacity_mod);
		power:							(TaitInterurban_Power * 2);
		weight:							TaitInterurban_Weight ton;

        variant_group: 					Item_TaitInterurban_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_TaitInterurban_Liv1_frontcheck;
        purchase: 						switch_TaitInterurban_Liv1_PurchaseStack;
        additional_text: 				string(STR_INFO_TAITINTERURBAN);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_TaitInterurban_Liv1_lencheck ;
        length:							TaitInterurban_Length;
        cargo_capacity:                 [TaitInterurban_CargoCapacity / param_capacity_mod];
        power:                          TaitInterurban_Power;
		weight:                        	TaitInterurban_Weight;
		running_cost_factor:            TaitInterurban_RunningCostFactor;
    }
}

