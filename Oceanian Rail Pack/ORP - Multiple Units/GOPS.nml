    return switch_Tait_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Tait_Liv0_pantocheck_at_1_r;
    return sw_Tait_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
