    1 : switch_SydneyStandardEMU_Liv0_NonControlMotorStack_r;
    return switch_SydneyStandard_EMU_Liv0_Trailer_Random;
}
switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_SydneyStandardEMU_Liv0_NonControlMotorStack;
    return switch_SydneyStandard_EMU_Liv0_Trailer_Random;
}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_SydneyStandardEMU_Liv0_pantocheck_at_1;
    return sw_SydneyStandardEMU_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_SydneyStandardEMU_Liv0_pantocheck_at_1;
