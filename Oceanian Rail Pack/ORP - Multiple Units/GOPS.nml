switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Tait_Liv0_pantocheck_at_2_r;
    return sw_Tait_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : switch_Tait_Liv0_TrailerStack;
    3 : sw_Tait_Liv0_pantocheck_at_1_r;
    4 : sw_Tait_Liv0_sidecheck_4_r;
    5 : sw_Tait_Liv0_pantocheck_at_2_r;
    6 .. 7 : sw_Tait_Liv0_sidecheck_6_r;
    return sw_Tait_Liv0_sidecheck_other_r;
}

//Forward

