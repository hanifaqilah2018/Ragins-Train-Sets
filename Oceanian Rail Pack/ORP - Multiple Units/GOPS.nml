//power
const Harris_Power = 200; //MU power is for 2 individual vehicles
//weight
const Harris_Weight = 39;

//Pantographs
spriteset(spriteset_Harris_Panto_Purchase,   "gfx/Harris_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Harris_PantoDown,   "gfx/Harris_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Harris_PantoDown_r,   "gfx/Harris_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_Harris_PantoUp,   "gfx/Harris_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_Harris_PantoUp_r,   "gfx/Harris_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Harris_Fw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Harris_PantoDown;
 1: spriteset_Harris_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_Harris_Rw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Harris_PantoDown_r; //might need switching back to just panto down
 1: spriteset_Harris_PantoUp_r;
}

//Harris_Liv0
spriteset(spriteset_Harris_Liv0_purchase,   "gfx/Harris_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Harris_Liv0_lead,   "gfx/Harris_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_Harris_Liv0_lead_r,   "gfx/Harris_Liv0.png") {template_8_r(7, 39)}
