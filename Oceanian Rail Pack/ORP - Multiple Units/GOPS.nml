//Backward
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_Tait_Liv0_NonControlMotorStack_r;
    return switch_Tait_Liv0_TrailerStack;
}
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_Tait_Liv0_NonControlMotorStack;
    return switch_Tait_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_Tait_Liv0_NonControlMotorStack_r;
    return switch_Tait_Liv0_TrailerStack;
}

