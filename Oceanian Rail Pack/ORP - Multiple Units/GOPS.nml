//Midcars
switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_Hitachi_Liv0_NonControlMotorStack_r;
    return spriteset_Hitachi_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Hitachi_Liv0_NonControlMotorStack;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Hitachi_Liv0_NonControlMotorStack_r;
    return spriteset_Hitachi_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Hitachi_Liv0_NonControlMotorStack;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Hitachi_Liv0_pantocheck_at_1;
    return sw_Hitachi_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Hitachi_Liv0_pantocheck_at_1;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Hitachi_Liv0_pantocheck_at_2;
    return sw_Hitachi_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Hitachi_Liv0_Trailer;
    3 : sw_Hitachi_Liv0_pantocheck_at_1;
    4 : sw_Hitachi_Liv0_sidecheck_4;
    5 : sw_Hitachi_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Hitachi_Liv0_sidecheck_6;
    return sw_Hitachi_Liv0_sidecheck_other;
}

//Endcars
switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Hitachi_Liv0_MotorStack;        //Front panto
    return switch_Hitachi_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Hitachi_Liv0_panto_direction;        //Not flipped, give Panto
    return switch_Hitachi_Liv0_Lead_Timeline;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Hitachi_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_Hitachi_Liv0_panto_flipcheck; //More Checks
}

