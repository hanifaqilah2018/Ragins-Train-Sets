item(FEAT_TRAINS, Item_Comeng_XPT_Liv4, Comeng_XPT_ID_Liv4) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_DIESEL;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		visual_effect_and_powered(VISUAL_EFFECT_DIESEL, 3, DISABLE_WAGON_POWER);

        name:                           string(STR_NAME_COMENG_XPT);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Comeng_XPT_IntroDate;		
		length:                         7;
		
		loading_speed:					SD_Express_LoadingSpeed;
		speed:							Comeng_XPT_Speed km/h;
		cost_factor:					(Comeng_XPT_CostFactor * 2);
		running_cost_factor:			(Comeng_XPT_RunningCostFactor * 2);
		cargo_capacity: 				0;
		power:							Comeng_XPT_Power;
		weight:							Comeng_XPT_Weight ton;

        variant_group: 					Item_Comeng_XPT_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_Comeng_XPT_Liv4_PowerCar;
        purchase: 						spriteset_Comeng_XPT_Liv4_purchase;
        additional_text: 				string(STR_INFO_COMENG_XPT);
    }
    livery_override (Item_MU_Trailer){
        default: 						switch_Comeng_XPT_Liv4_Trailer ;
        length: 						8;
        cargo_capacity:                 (Comeng_XPT_CargoCapacity / param_capacity_mod);
        power:                          0;
		weight:                        	Comeng_XPT_Weight_T;
		running_cost_factor:            (Comeng_XPT_RunningCostFactor / 2); //maybe remove the divide?

    }
}

