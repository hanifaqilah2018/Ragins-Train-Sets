//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_SydneyStandardEMU_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_SydneyStandardEMU_Liv0_purchase;
	1: spriteset_SydneyStandardEMU_Panto_Purchase;
}

