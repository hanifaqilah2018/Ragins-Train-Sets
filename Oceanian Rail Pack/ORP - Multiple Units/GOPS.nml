}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Hitachi_Liv0_pantocheck_at_2_r;
    return sw_Hitachi_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Hitachi_Liv0_Trailer;
