}
switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_Hitachi_Liv0_NonControlMotorStack;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_Hitachi_Liv0_NonControlMotorStack_r;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_0_r, position_in_vehid_chain % 2){
    1 : spriteset_Hitachi_Liv0_Trailer;
    return switch_Hitachi_Liv0_NonControlMotorStack;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_pantocheck_at_1r_r, position_in_vehid_chain_from_end % 2){
    1 : switch_Hitachi_Liv0_NonControlMotorStack;
    return spriteset_Hitachi_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Hitachi_Liv0_pantocheck_at_1_r;
    return sw_Hitachi_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_Hitachi_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : spriteset_Hitachi_Liv0_Trailer;
