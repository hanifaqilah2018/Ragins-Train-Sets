//Tait_Liv0
spriteset(spriteset_Tait_Liv0_purchase,   "gfx/Tait_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Tait_Liv0_lead,   "gfx/Tait_Liv0.png") {template_8(7, 39)}
