//Pantographs
spriteset(spriteset_Comeng_SMU_Panto_Purchase,   "gfx/Comeng_SMU_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Comeng_SMU_PantoDown,   "gfx/Comeng_SMU_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Comeng_SMU_PantoDown_r,   "gfx/Comeng_SMU_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_Comeng_SMU_PantoUp,   "gfx/Comeng_SMU_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_Comeng_SMU_PantoUp_r,   "gfx/Comeng_SMU_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Comeng_SMU_Fw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Comeng_SMU_PantoDown;
 1: spriteset_Comeng_SMU_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_Comeng_SMU_Rw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Comeng_SMU_PantoDown_r;
 1: spriteset_Comeng_SMU_PantoUp_r;
}

//Comeng_SMU_Liv0
spriteset(spriteset_Comeng_SMU_Liv0_purchase,   "gfx/Comeng_SMU_Liv0.png") {template_purchase_88mu(7, 21)}
