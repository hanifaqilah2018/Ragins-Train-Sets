spriteset(spriteset_TullochSuburbanEMU_PantoUp,   "gfx/TullochSuburbanEMU_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_TullochSuburbanEMU_PantoUp_r,   "gfx/TullochSuburbanEMU_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_TullochSuburbanEMU_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_TullochSuburbanEMU_PantoDown;
 1: spriteset_TullochSuburbanEMU_PantoUp;
}

