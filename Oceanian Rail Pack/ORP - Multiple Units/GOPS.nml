//Vehicle
item (FEAT_TRAINS, Item_MU_Trailer, 0) {
    property {
        sprite_id:                        SPRITE_ID_NEW_TRAIN;
        refit_cost:                        0;
        climates_available:                ALL_CLIMATES;
        bitmask_vehicle_info:            0;
        misc_flags:                        bitmask(TRAIN_FLAG_TILT, TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here

        track_type:                        [NG_RAIL, RAIL, BG_RAIL];
		running_cost_base: 				RUNNING_COST_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;

        name:                            string(STR_MU_TRAILER);
        introduction_date:                date(1890,1,1);
        model_life:                        VEHICLE_NEVER_EXPIRES;
        length:                            8;

        weight:                         0 ton;
        speed:                            0 mph;
		power:                            0 hp;
        cost_factor:                     100;
        running_cost_factor:             10;

        refittable_cargo_classes:        bitmask();
        default_cargo_type:                PASS;
        cargo_capacity:                    100;
        loading_speed: 30;

    }
    graphics {
        default:                        spriteset_MU_trailer;
        purchase:                        spriteset_MU_purchase;
        additional_text: string(STR_MU_TRAILER_INFO);

}
}

//ID
const NSW600700Railmotor_ID = 5300;
//introduction_date
const NSW600700Railmotor_IntroDate = date(1949, 1, 1);
//speed
const NSW600700Railmotor_Speed = 115;
//cost_factor
const NSW600700Railmotor_CostFactor = 23;
//running_cost_factor
const NSW600700Railmotor_RunningCostFactor = 58;
//Cargo Capacity
const NSW600700Railmotor_CargoCapacity = 100;
//power
const NSW600700Railmotor_Power = 660;
//weight
const NSW600700Railmotor_Weight = 38;

//NSW600700Railmotor_Liv0
spriteset(spriteset_NSW600700Railmotor_Liv0_purchase,   "gfx/NSW600700Railmotor_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_NSW600700Railmotor_Liv0_lead,   "gfx/NSW600700Railmotor_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_NSW600700Railmotor_Liv0_DT_lead,   "gfx/NSW600700Railmotor_Liv0.png") {template_8(7, 69)}
spriteset(spriteset_NSW600700Railmotor_Liv0_Trailer,   "gfx/NSW600700Railmotor_Liv0.png") {template_8_repeat(7, 99)}

switch(FEAT_TRAINS, SELF, switch_NSW600700Railmotor_Liv0_forward, vehicle_is_flipped){
    0:	spriteset_NSW600700Railmotor_Liv0_lead;
    1: 	spriteset_NSW600700Railmotor_Liv0_DT_lead;
}

switch(FEAT_TRAINS, SELF, switch_NSW600700Railmotor_Liv0_rev, vehicle_is_flipped){
    0:  spriteset_NSW600700Railmotor_Liv0_DT_lead;
    1: 	spriteset_NSW600700Railmotor_Liv0_lead;
}

switch(FEAT_TRAINS, PARENT, switch_NSW600700Railmotor_Liv0_directioncheck, vehicle_is_reversed){ 
    0:    switch_NSW600700Railmotor_Liv0_forward;
    1:    switch_NSW600700Railmotor_Liv0_rev;
}

const NSW600700Railmotor_ID_Liv0 = (NSW600700Railmotor_ID + Liv0_ID );

item(FEAT_TRAINS, Item_NSW600700Railmotor_Liv0, NSW600700Railmotor_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_DIESEL;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_DIESEL;

        name:                           string(STR_NAME_NSW600700RAILMOTOR);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              NSW600700Railmotor_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							NSW600700Railmotor_Speed km/h;
		cost_factor:					(NSW600700Railmotor_CostFactor * 2);
		running_cost_factor:			(NSW600700Railmotor_RunningCostFactor * 2);
		cargo_capacity: 				(NSW600700Railmotor_CargoCapacity / param_capacity_mod);
		power:							(NSW600700Railmotor_Power * 2);
		weight:							NSW600700Railmotor_Weight ton;

//        variant_group: 					Item_NSW600700Railmotor_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_NSW600700Railmotor_Liv0_directioncheck;
        purchase: 						spriteset_NSW600700Railmotor_Liv0_purchase;
        additional_text: 				string(STR_INFO_NSW600700RAILMOTOR);
    }
    livery_override (Item_MU_Trailer){
        default: 						spriteset_NSW600700Railmotor_Liv0_Trailer ;
        length: 						8;
        cargo_capacity:                 (NSW600700Railmotor_CargoCapacity / param_capacity_mod);
        power:                          NSW600700Railmotor_Power;
		weight:                        	NSW600700Railmotor_Weight;
		running_cost_factor:            (NSW600700Railmotor_RunningCostFactor / 2); //maybe remove the divide?

    }
}

