item(FEAT_TRAINS, Item_Comeng_SMU_Liv0, Comeng_SMU_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_COMENG_SMU);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Comeng_SMU_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Comeng_SMU_Speed km/h;
		cost_factor:					(Comeng_SMU_CostFactor * 2);
		running_cost_factor:			(Comeng_SMU_RunningCostFactor * 2);
		cargo_capacity: 				(Comeng_SMU_CargoCapacity / param_capacity_mod);
		power:							(Comeng_SMU_Power * 2);
		weight:							Comeng_SMU_Weight ton;

//        variant_group: 					Item_Comeng_SMU_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Comeng_SMU_Liv0_directioncheck;
        purchase: 						switch_Comeng_SMU_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_COMENG_SMU);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_Comeng_SMU_Liv0_revcheck ;
        length:							8;
        cargo_capacity:                 [Comeng_SMU_CargoCapacity / param_capacity_mod];
        power:                          Comeng_SMU_Power;
		weight:                        	Comeng_SMU_Weight;
		running_cost_factor:            Comeng_SMU_RunningCostFactor;

    }
}

//ID
const Comeng_VSet_ID = 14040;
//introduction_date
const Comeng_VSet_IntroDate = date(1970, 1, 1);
//speed
const Comeng_VSet_Speed = 145; //verify at a later date, 110 km/h seems rather high
//cost_factor
const Comeng_VSet_CostFactor = 41;
//running_cost_factor
const Comeng_VSet_RunningCostFactor = 105;
//Cargo Capacity
const Comeng_VSet_CargoCapacity = 130;
//power
const Comeng_VSet_Power = 400;
//weight
const Comeng_VSet_Weight = 50;

//Pantographs
spriteset(spriteset_Comeng_VSet_Panto_Purchase,   "gfx/Comeng_VSet_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Comeng_VSet_PantoDown,   "gfx/Comeng_VSet_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Comeng_VSet_PantoDown_r,   "gfx/Comeng_VSet_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_Comeng_VSet_PantoUp,   "gfx/Comeng_VSet_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_Comeng_VSet_PantoUp_r,   "gfx/Comeng_VSet_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Comeng_VSet_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_Comeng_VSet_PantoDown;
 1: spriteset_Comeng_VSet_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_Comeng_VSet_Rw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_Comeng_VSet_PantoDown_r; //might need switching back to just panto down
 1: spriteset_Comeng_VSet_PantoUp_r;
}

//Comeng_VSet_Liv0
spriteset(spriteset_Comeng_VSet_Liv0_purchase,   "gfx/Comeng_VSet_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Comeng_VSet_Liv0_lead,   "gfx/Comeng_VSet_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_Comeng_VSet_Liv0_Trailer,   "gfx/Comeng_VSet_Liv0.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Comeng_VSet_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_VSet_Liv0_purchase;
	1: spriteset_Comeng_VSet_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_Comeng_VSet_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_VSet_Liv0_lead;
	1: switch_Comeng_VSet_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_Comeng_VSet_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_VSet_Liv0_lead;
	1: switch_Comeng_VSet_Fw_railtype;
}

//N Lead
switch (FEAT_TRAINS, SELF, switch_Comeng_VSet_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_VSet_Liv0_Trailer;
	1: switch_Comeng_VSet_Fw_railtype;
}
//N Rear
switch (FEAT_TRAINS, SELF, switch_Comeng_VSet_Liv0_NonControlMotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_VSet_Liv0_Trailer;
	1: switch_Comeng_VSet_Rw_railtype;
}

//Backward
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_Comeng_VSet_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_Comeng_VSet_Liv0_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_Comeng_VSet_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_0_r, position_in_vehid_chain % 2){
    1 : spriteset_Comeng_VSet_Liv0_Trailer;
    return switch_Comeng_VSet_Liv0_NonControlMotorStack;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_1r_r, position_in_vehid_chain_from_end % 2){
    1 : switch_Comeng_VSet_Liv0_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv0_pantocheck_at_1_r;
    return sw_Comeng_VSet_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : spriteset_Comeng_VSet_Liv0_Trailer;
    return sw_Comeng_VSet_Liv0_pantocheck_at_0_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv0_pantocheck_at_2_r;
    return sw_Comeng_VSet_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Comeng_VSet_Liv0_Trailer;
    3 : sw_Comeng_VSet_Liv0_pantocheck_at_1_r;
    4 : sw_Comeng_VSet_Liv0_sidecheck_4_r;
    5 : sw_Comeng_VSet_Liv0_pantocheck_at_2_r;
    6 .. 7 : sw_Comeng_VSet_Liv0_sidecheck_6_r;
    return sw_Comeng_VSet_Liv0_sidecheck_other_r;
}

//Forward

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_Comeng_VSet_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Comeng_VSet_Liv0_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

