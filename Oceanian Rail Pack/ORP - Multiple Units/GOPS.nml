item(FEAT_TRAINS, Item_Tait_Single_Liv0, Tait_ID_Single_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TAIT);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Tait_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Tait_Speed km/h;
		cost_factor:					Tait_CostFactor;
		running_cost_factor:			Tait_RunningCostFactor;
		cargo_capacity: 				Tait_CargoCapacity;
		power:							Tait_Power;
		weight:							Tait_Weight ton;

//        variant_group: 					Item_Tait_Liv0;
		extra_flags:					bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB);
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY, VEHICLE_FLAG_TRAIN_HAS_CAB);
    }
    graphics {
        default: 						switch_Tait_Single_Liv0_stack;
        purchase: 						switch_Tait_Single_Liv0_Purchasestack;
        additional_text: 				string(STR_INFO_TAIT);
		reverse_build_probability: 		return 50;
}
}

//Tait_Liv0 Multiple Unit
//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_purchase;
	1: switch_Tait_Roof_Transition_Purchase;
	2: spriteset_Tait_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_lead;
	1: switch_Tait_Roof_Transition_Motor;
	2: switch_Tait_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_lead;
	1: switch_Tait_Roof_Transition_Motor;
	2: switch_Tait_Fw_railtype;
}

//D Lead
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_DrivingTrailerStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_lead;
	1: switch_Tait_Roof_Transition_Motor;
}

//N Lead
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_lead;
	1: switch_Tait_Roof_Transition_Motor;
	2: switch_Tait_Fw_railtype;
}
//N Rear
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_NonControlMotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_lead_r;
	1: switch_Tait_Roof_Transition_Motor_r;
	2: switch_Tait_Rw_railtype;
}

//T
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_TrailerStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_Trailer;
	1: switch_Tait_Roof_Transition_Trailer;
}

//Midcars
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_Tait_Liv0_NonControlMotorStack_r;
    return switch_Tait_Liv0_TrailerStack;
}
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Tait_Liv0_NonControlMotorStack;
    return switch_Tait_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Tait_Liv0_NonControlMotorStack_r;
    return switch_Tait_Liv0_TrailerStack;
}
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Tait_Liv0_NonControlMotorStack;
    return switch_Tait_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Tait_Liv0_pantocheck_at_1;
    return sw_Tait_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Tait_Liv0_pantocheck_at_1;
    return switch_Tait_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Tait_Liv0_pantocheck_at_2;
    return sw_Tait_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : switch_Tait_Liv0_TrailerStack;
    3 : sw_Tait_Liv0_pantocheck_at_1;
    4 : sw_Tait_Liv0_sidecheck_4;
    5 : sw_Tait_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Tait_Liv0_sidecheck_6;
    return sw_Tait_Liv0_sidecheck_other;
}

//End Cars
switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Tait_Liv0_MotorStack;
    return switch_Tait_Liv0_MotorStack_r;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Tait_Liv0_panto_direction;
    return switch_Tait_Liv0_DrivingTrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_Tait_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Tait_Liv0_panto_direction;
    return sw_Tait_Liv0_panto_flipcheck;
}

const Tait_ID_Liv0 = (Tait_ID_Single_Liv0 + 10);

item(FEAT_TRAINS, Item_Tait_Liv0, Tait_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TAIT_MU);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Tait_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Tait_Speed km/h;
		cost_factor:					(Tait_CostFactor * 2);
		running_cost_factor:			(Tait_RunningCostFactor * 2);
		cargo_capacity: 				(Tait_CargoCapacity / param_capacity_mod);
		power:							(Tait_Power * 2);
		weight:							Tait_Weight ton;

//        variant_group: 					Item_Tait_MU_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Tait_Liv0_frontcheck;
        purchase: 						switch_Tait_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_TAIT_MU);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_Tait_Liv0_lencheck ;
        length:							8;
        cargo_capacity:                 [Tait_CargoCapacity / param_capacity_mod];
        power:                          Tait_Power;
		weight:                        	Tait_Weight;
		running_cost_factor:            Tait_RunningCostFactor;

    }
}

//ID
const SydneyStandardEMU_ID = 11140;
//introduction_date
const SydneyStandardEMU_IntroDate = date(1926, 1, 1);
//speed
const SydneyStandardEMU_Speed = 115;
//cost_factor
const SydneyStandardEMU_CostFactor = 19;
//running_cost_factor
const SydneyStandardEMU_RunningCostFactor = 49;
//Cargo Capacity
const SydneyStandardEMU_CargoCapacity = 90;
//power
const SydneyStandardEMU_Power = 360;
//weight
const SydneyStandardEMU_Weight = 43;

//Pantographs
spriteset(spriteset_SydneyStandardEMU_Panto_Purchase,   "gfx/SydneyStandardEMU_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_SydneyStandardEMU_PantoDown,   "gfx/SydneyStandardEMU_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_SydneyStandardEMU_PantoDown_r,   "gfx/SydneyStandardEMU_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_SydneyStandardEMU_PantoUp,   "gfx/SydneyStandardEMU_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_SydneyStandardEMU_PantoUp_r,   "gfx/SydneyStandardEMU_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_SydneyStandardEMU_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_SydneyStandardEMU_PantoDown;
 1: spriteset_SydneyStandardEMU_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_SydneyStandardEMU_Rw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_SydneyStandardEMU_PantoDown_r; //might need switching back to just panto down
 1: spriteset_SydneyStandardEMU_PantoUp_r;
}

