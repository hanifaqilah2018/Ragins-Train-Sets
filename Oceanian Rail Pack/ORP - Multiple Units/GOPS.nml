 random_switch(FEAT_TRAINS, SELF, switch_SydneyStandard_EMU_Liv0_Trailer_Random){
    1 : spriteset_SydneyStandardEMU_Liv0_Trailer;
    1 : spriteset_SydneyStandardEMU_Liv0_Trailer_r;
}

//Midcars
switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_SydneyStandardEMU_Liv0_NonControlMotorStack_r;
    return switch_SydneyStandard_EMU_Liv0_Trailer_Random;
}
