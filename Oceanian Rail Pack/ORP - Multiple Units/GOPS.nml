spriteset(spriteset_Comeng_SMU_Liv0_lead_r,   "gfx/Comeng_SMU_Liv0.png") {template_8_r(7, 39)}
spriteset(spriteset_Comeng_SMU_Liv0_Trailer,   "gfx/Comeng_SMU_Liv0.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Comeng_SMU_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_SMU_Liv0_purchase;
	1: spriteset_Comeng_SMU_Panto_Purchase;
}
//C Lead
switch (FEAT_TRAINS, SELF, switch_Comeng_SMU_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_SMU_Liv0_lead;
	1: switch_Comeng_SMU_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_Comeng_SMU_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_SMU_Liv0_lead;
	1: switch_Comeng_SMU_Fw_railtype;
}
//N Lead
switch (FEAT_TRAINS, SELF, switch_Comeng_SMU_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_SMU_Liv0_lead;
