//Backward
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_2_r, position_in_vehid_chain % 3){
    2 : switch_Comeng_SMU_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_2r_r, position_in_vehid_chain_from_end % 3){
    2 : switch_Comeng_SMU_Liv0_NonControlMotorStack;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_1_r, position_in_vehid_chain % 2){
    1 : switch_Comeng_SMU_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_0_r, position_in_vehid_chain % 2){
    1 : spriteset_Comeng_SMU_Liv0_Trailer;
    return switch_Comeng_SMU_Liv0_NonControlMotorStack;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_1r_r, position_in_vehid_chain_from_end % 2){
    1 : switch_Comeng_SMU_Liv0_NonControlMotorStack;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_other_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_SMU_Liv0_pantocheck_at_1_r;
    return sw_Comeng_SMU_Liv0_pantocheck_at_1r_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_4_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : spriteset_Comeng_SMU_Liv0_Trailer;
    return sw_Comeng_SMU_Liv0_pantocheck_at_0_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_6_r, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_SMU_Liv0_pantocheck_at_2_r;
    return sw_Comeng_SMU_Liv0_pantocheck_at_2r_r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_lencheck_r, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Comeng_SMU_Liv0_Trailer;
    3 : sw_Comeng_SMU_Liv0_pantocheck_at_1_r;
    4 : sw_Comeng_SMU_Liv0_sidecheck_4_r;
    5 : sw_Comeng_SMU_Liv0_pantocheck_at_2_r;
    6 .. 7 : sw_Comeng_SMU_Liv0_sidecheck_6_r;
    return sw_Comeng_SMU_Liv0_sidecheck_other_r;
}

//Forward

