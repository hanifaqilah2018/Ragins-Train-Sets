}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : switch_SydneyStandard_EMU_Liv0_Trailer_Random;
    3 : sw_SydneyStandardEMU_Liv0_pantocheck_at_1;
    4 : sw_SydneyStandardEMU_Liv0_sidecheck_4;
    5 : sw_SydneyStandardEMU_Liv0_pantocheck_at_2;
    6 .. 7 : sw_SydneyStandardEMU_Liv0_sidecheck_6;
    return sw_SydneyStandardEMU_Liv0_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_SydneyStandardEMU_Liv0_MotorStack;        //Front panto
    return switch_SydneyStandardEMU_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_SydneyStandardEMU_Liv0_panto_direction;        //Not flipped, give Panto
    return spriteset_SydneyStandardEMU_Liv0_DT_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_SydneyStandardEMU_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_SydneyStandardEMU_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_SydneyStandardEMU_Liv0_panto_flipcheck; //More Checks
}

