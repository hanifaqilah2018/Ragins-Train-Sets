//introduction_date
const TullochSuburbanEMU_IntroDate = date(1940, 1, 1);
//speed
const TullochSuburbanEMU_Speed = 115;
//cost_factor
const TullochSuburbanEMU_CostFactor = 19;
//running_cost_factor
const TullochSuburbanEMU_RunningCostFactor = 49;
//Cargo Capacity
const TullochSuburbanEMU_CargoCapacity = 90;
//power
const TullochSuburbanEMU_Power = 360;
//weight
const TullochSuburbanEMU_Weight = 43;

//Pantographs
spriteset(spriteset_TullochSuburbanEMU_Panto_Purchase,   "gfx/TullochSuburbanEMU_Pantographs.png") {template_purchase_88mu(7, 21)}
