const TullochInterurban_ID_Liv2 = (TullochInterurban_ID + Liv2_ID);

item(FEAT_TRAINS, Item_TullochInterurban_Liv2, TullochInterurban_ID_Liv2) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_FictionalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TULLOCHINTERURBAN);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              TullochInterurban_IntroDate;		
		length:                         TullochInterurban_Length;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							TullochInterurban_Speed km/h;
		cost_factor:					(TullochInterurban_CostFactor * 2);
		running_cost_factor:			(TullochInterurban_RunningCostFactor * 2);
		cargo_capacity: 				(TullochInterurban_CargoCapacity / param_capacity_mod);
		power:							(TullochInterurban_Power * 2);
		weight:							TullochInterurban_Weight ton;

        variant_group: 					Item_TullochInterurban_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_TullochInterurban_Liv2_frontcheck;
        purchase: 						switch_TullochInterurban_Liv2_PurchaseStack;
        additional_text: 				string(STR_INFO_TULLOCHINTERURBAN);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_TullochInterurban_Liv2_lencheck ;
        length:							TullochInterurban_Length;
        cargo_capacity:                 [TullochInterurban_CargoCapacity / param_capacity_mod];
        power:                          TullochInterurban_Power;
		weight:                        	TullochInterurban_Weight;
		running_cost_factor:            TullochInterurban_RunningCostFactor;
    }
}

