    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TaitInterurban_Liv0_Trailer;
	1: switch_TaitInterurban_Roof_Transition_Trailer;
}

//Midcars
switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_TaitInterurban_Liv0_NonControlMotorStack_r;
    return switch_TaitInterurban_Liv0_TrailerStack;
}
switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_TaitInterurban_Liv0_NonControlMotorStack;
    return switch_TaitInterurban_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_TaitInterurban_Liv0_NonControlMotorStack_r;
    return switch_TaitInterurban_Liv0_TrailerStack;
}
switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_TaitInterurban_Liv0_NonControlMotorStack;
    return switch_TaitInterurban_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TaitInterurban_Liv0_pantocheck_at_1;
    return sw_TaitInterurban_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TaitInterurban_Liv0_pantocheck_at_1;
    return switch_TaitInterurban_Liv0_TrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TaitInterurban_Liv0_pantocheck_at_2;
    return sw_TaitInterurban_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : switch_TaitInterurban_Liv0_TrailerStack;
    3 : sw_TaitInterurban_Liv0_pantocheck_at_1;
    4 : sw_TaitInterurban_Liv0_sidecheck_4;
    5 : sw_TaitInterurban_Liv0_pantocheck_at_2;
    6 .. 7 : sw_TaitInterurban_Liv0_sidecheck_6;
    return sw_TaitInterurban_Liv0_sidecheck_other;
}

//End Cars
switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_TaitInterurban_Liv0_MotorStack;
    return switch_TaitInterurban_Liv0_MotorStack_r;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_TaitInterurban_Liv0_panto_direction;
    return switch_TaitInterurban_Liv0_DrivingTrailerStack;
}

switch(FEAT_TRAINS, SELF, sw_TaitInterurban_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_TaitInterurban_Liv0_panto_direction;
    return sw_TaitInterurban_Liv0_panto_flipcheck;
}

