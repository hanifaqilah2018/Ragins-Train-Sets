		running_cost_factor:			(XTrapolis100_RunningCostFactor * 2);
		cargo_capacity: 				(XTrapolis100_CargoCapacity / param_capacity_mod);
		power:							(XTrapolis100_Power * 2);
		weight:							XTrapolis100_Weight ton;

//        variant_group: 					Item_XTrapolis100_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_XTrapolis100_Liv0_endcars;
        purchase: 						switch_XTrapolis100_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_XTRAPOLIS100);
    }
    livery_override (Item_MU_Trailer){
        default:						switch_XTrapolis100_Liv0_midcars;
        length:							8;
        cargo_capacity:                 [XTrapolis100_CargoCapacity / param_capacity_mod];
        power:                          XTrapolis100_Power;
		weight:                        	XTrapolis100_Weight;
		running_cost_factor:            XTrapolis100_RunningCostFactor;

    }
}

//XTrapolis100_Liv1
spriteset(spriteset_XTrapolis100_Liv1_purchase,   "gfx/XTrapolis100_Liv1.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_XTrapolis100_Liv1_lead,   "gfx/XTrapolis100_Liv1.png") {template_8(7, 39)}
spriteset(spriteset_XTrapolis100_Liv1_lead_r,   "gfx/XTrapolis100_Liv1.png") {template_8_r(7, 39)}
spriteset(spriteset_XTrapolis100_Liv1_Trailer,   "gfx/XTrapolis100_Liv1.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_XTrapolis100_Liv1_purchase;
	1: spriteset_XTrapolis100_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_LeadStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_XTrapolis100_Liv1_lead;
	1: switch_XTrapolis100_Fw_railtype;
}

//Pantograph cars
//Swap normal & _r cars to swap pantograph arrangements
switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_PantoCarStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_XTrapolis100_Liv1_Trailer;
	1: switch_XTrapolis100_Fw_railtype;
}

switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_PantoCarStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_XTrapolis100_Liv1_Trailer;
	1: switch_XTrapolis100_Rw_railtype;
}

/* Midcars */
        // Penultipantos
        switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_pantos_large_forwards, position_in_vehid_chain ) {                
                0:  switch_XTrapolis100_Liv1_PantoCarStack;
                switch_XTrapolis100_Liv1_PantoCarStack_r;          
            }
        switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_forwards_length_large, (position_in_vehid_chain == 0) || (position_in_vehid_chain_from_end == 0 )) {                
                1:  switch_XTrapolis100_Liv1_pantos_large_forwards;
                spriteset_XTrapolis100_Liv1_Trailer;        
            }
        // Panto in Middle
        switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_forwards_length_small, (position_in_vehid_chain == position_in_vehid_chain_from_end ) || (position_in_vehid_chain - 1 == position_in_vehid_chain_from_end) ) {                
                0:  spriteset_XTrapolis100_Liv1_Trailer;
                switch_XTrapolis100_Liv1_PantoCarStack;                
            }
    switch (FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_midcars, num_vehs_in_vehid_chain) {
            0..1: switch_XTrapolis100_Liv1_forwards_length_large;
            2:  switch_XTrapolis100_Liv1_forwards_length_small;
            switch_XTrapolis100_Liv1_forwards_length_large;
        }

//End Car Controls
switch(FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_panto_flipcheck, vehicle_is_flipped){
    0 : spriteset_XTrapolis100_Liv1_lead;        //Not flipped, give Panto
    return switch_XTrapolis100_Liv1_LeadStack;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, switch_XTrapolis100_Liv1_endcars, position_in_vehid_chain){
    0: spriteset_XTrapolis100_Liv1_lead; //We need a pantograph, guaranteed
    return switch_XTrapolis100_Liv1_panto_flipcheck; //More Checks
}

const XTrapolis100_ID_Liv1 = (XTrapolis100_ID + Liv1_ID);

item(FEAT_TRAINS, Item_XTrapolis100_Liv1, XTrapolis100_ID_Liv1) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_TILT,TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_ProposalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_XTRAPOLIS100);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              XTrapolis100_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							XTrapolis100_Speed km/h;
		cost_factor:					(XTrapolis100_CostFactor * 2);
		running_cost_factor:			(XTrapolis100_RunningCostFactor * 2);
		cargo_capacity: 				(XTrapolis100_CargoCapacity / param_capacity_mod);
		power:							(XTrapolis100_Power * 2);
		weight:							XTrapolis100_Weight ton;

        variant_group: 					Item_XTrapolis100_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_XTrapolis100_Liv1_endcars;
        purchase: 						switch_XTrapolis100_Liv1_PurchaseStack;
        additional_text: 				string(STR_INFO_XTRAPOLIS100);
    }
    livery_override (Item_MU_Trailer){
        default:						switch_XTrapolis100_Liv1_midcars;
        length:							8;
        cargo_capacity:                 [XTrapolis100_CargoCapacity / param_capacity_mod];
        power:                          XTrapolis100_Power;
		weight:                        	XTrapolis100_Weight;
		running_cost_factor:            XTrapolis100_RunningCostFactor;

    }
}

//ID
