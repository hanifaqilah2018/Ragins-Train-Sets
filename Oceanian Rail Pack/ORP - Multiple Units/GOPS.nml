//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_TaitInterurban_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TaitInterurban_Liv0_purchase;
	1: switch_TaitInterurban_Roof_Transition_Purchase;
	2: spriteset_TaitInterurban_Panto_Purchase;
}

