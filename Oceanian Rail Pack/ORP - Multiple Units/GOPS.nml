spriteset(spriteset_AucklandART_PantoUp_r,   "gfx/AucklandART_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_AucklandART_Fw_railtype, tile_powers_railtype("NG_RAIL_OHLE_AC")) {
 0: spriteset_AucklandART_PantoDown;
 1: spriteset_AucklandART_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_AucklandART_Rw_railtype, tile_powers_railtype("NG_RAIL_OHLE_AC")) {
 0: spriteset_AucklandART_PantoDown_r; //might need switching back to just panto down
 1: spriteset_AucklandART_PantoUp_r;
}

//AucklandART_Liv0
spriteset(spriteset_AucklandART_Liv0_purchase,   "gfx/AucklandART_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_AucklandART_Liv0_lead,   "gfx/AucklandART_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_AucklandART_Liv0_lead_r,   "gfx/AucklandART_Liv0.png") {template_8_r(7, 39)}
spriteset(spriteset_AucklandART_Liv0_Trailer,   "gfx/AucklandART_Liv0.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_AucklandART_Liv0_purchase;
	1: spriteset_AucklandART_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_LeadStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_AucklandART_Liv0_lead;
	1: switch_AucklandART_Fw_railtype;
}

//Pantograph cars
//Swap normal & _r cars to swap pantograph arrangements
switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_PantoCarStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_AucklandART_Liv0_Trailer;
	1: switch_AucklandART_Fw_railtype;
}

switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_PantoCarStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_AucklandART_Liv0_Trailer;
	1: switch_AucklandART_Rw_railtype;
}

/* Midcars */
    // Backwards
        // Penultipantos
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_pantos_large_backwards, position_in_vehid_chain_from_end ) {
                0:  switch_AucklandART_Liv0_PantoCarStack_r;
                switch_AucklandART_Liv0_PantoCarStack;
            }
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_backwards_length_large, (position_in_vehid_chain == 0) || (position_in_vehid_chain_from_end == 0 )) {                
                1:  switch_AucklandART_Liv0_pantos_large_backwards;
                spriteset_AucklandART_Liv0_Trailer;            
            }
        //Panto in Middle
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_backwards_length_small, (position_in_vehid_chain == position_in_vehid_chain_from_end ) || (position_in_vehid_chain - 1 == position_in_vehid_chain_from_end) ) {                
                0:  switch_AucklandART_Liv0_PantoCarStack_r;
                spriteset_AucklandART_Liv0_Trailer;                    
            }
    switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_backwards_length, num_vehs_in_vehid_chain) {
            0..1: switch_AucklandART_Liv0_backwards_length_large;
            2: switch_AucklandART_Liv0_backwards_length_small;
            switch_AucklandART_Liv0_backwards_length_large;
        }

    // Forwards
        // Penultipantos
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_pantos_large_forwards, position_in_vehid_chain ) {                
                0:  switch_AucklandART_Liv0_PantoCarStack;
                switch_AucklandART_Liv0_PantoCarStack_r;          
            }
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_forwards_length_large, (position_in_vehid_chain == 0) || (position_in_vehid_chain_from_end == 0 )) {                
                1:  switch_AucklandART_Liv0_pantos_large_forwards;
                spriteset_AucklandART_Liv0_Trailer;        
            }
        // Panto in Middle
        switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_forwards_length_small, (position_in_vehid_chain == position_in_vehid_chain_from_end ) || (position_in_vehid_chain - 1 == position_in_vehid_chain_from_end) ) {                
                0:  spriteset_AucklandART_Liv0_Trailer;
                switch_AucklandART_Liv0_PantoCarStack;                
            }
    switch (FEAT_TRAINS, SELF, switch_AucklandART_Liv0_forwards_length, num_vehs_in_vehid_chain) {
            0..1: switch_AucklandART_Liv0_forwards_length_large;
            2:  switch_AucklandART_Liv0_forwards_length_small;
            switch_AucklandART_Liv0_forwards_length_large;
        }

    switch (FEAT_TRAINS, PARENT, switch_AucklandART_Liv0_midcars, vehicle_is_reversed) {                
            0:  switch_AucklandART_Liv0_forwards_length;
            switch_AucklandART_Liv0_backwards_length;                
        }
	


//End Car Controls
//Forwards
switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: spriteset_AucklandART_Liv0_lead; //Panto
    return switch_AucklandART_Liv0_LeadStack; //No Panto
}

switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : switch_AucklandART_Liv0_panto_direction_r_pos;        //Front panto
    return spriteset_AucklandART_Liv0_lead;    //Rear panto
}

switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : switch_AucklandART_Liv0_panto_direction_r;        //Not flipped, give Panto
    return spriteset_AucklandART_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_frontcheck_r, position_in_vehid_chain){
    0: switch_AucklandART_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return switch_AucklandART_Liv0_panto_flipcheck_r; //More Checks
}

//Backwardss
switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : spriteset_AucklandART_Liv0_lead;        //Not flipped, give Panto
    return switch_AucklandART_Liv0_LeadStack;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, switch_AucklandART_Liv0_frontcheck, position_in_vehid_chain){
    0: spriteset_AucklandART_Liv0_lead; //We need a pantograph, guaranteed
    return switch_AucklandART_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, switch_AucklandART_Liv0_directioncheck, vehicle_is_reversed){
    0: switch_AucklandART_Liv0_frontcheck; //We are going forwards
    return switch_AucklandART_Liv0_frontcheck_r; //We are going backwards
}

const AucklandART_ID_Liv0 = (AucklandART_ID + Liv0_ID);

item(FEAT_TRAINS, Item_AucklandART_Liv0, AucklandART_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     NG_RAIL_OHLE_AC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_ProposalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_AUCKLANDART);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              AucklandART_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							AucklandART_Speed km/h;
		cost_factor:					(AucklandART_CostFactor * 2);
		running_cost_factor:			(AucklandART_RunningCostFactor * 2);
		cargo_capacity: 				(AucklandART_CargoCapacity / param_capacity_mod);
		power:							(AucklandART_Power * 2);
		weight:							AucklandART_Weight ton;

//        variant_group: 					Item_AucklandART_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_AucklandART_Liv0_directioncheck;
        purchase: 						switch_AucklandART_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_AUCKLANDART);
    }
    livery_override (Item_MU_Trailer){
        default:						switch_AucklandART_Liv0_midcars;
        length:							8;
        cargo_capacity:                 [AucklandART_CargoCapacity / param_capacity_mod];
        power:                          AucklandART_Power;
		weight:                        	AucklandART_Weight;
		running_cost_factor:            AucklandART_RunningCostFactor;

    }
}

//ID
const Comeng_SMU_ID = 11400;
//introduction_date
const Comeng_SMU_IntroDate = date(1981, 1, 1);
//speed
const Comeng_SMU_Speed = 115;
//cost_factor
