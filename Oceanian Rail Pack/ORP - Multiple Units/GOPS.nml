    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Comeng_SMU_Liv0_lead_r;
	1: switch_Comeng_SMU_Rw_railtype;
}

//Midcars
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_Comeng_SMU_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Comeng_SMU_Liv0_NonControlMotorStack;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Comeng_SMU_Liv0_NonControlMotorStack_r;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Comeng_SMU_Liv0_NonControlMotorStack;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_SMU_Liv0_pantocheck_at_1;
    return sw_Comeng_SMU_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_SMU_Liv0_pantocheck_at_1;
    return spriteset_Comeng_SMU_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_SMU_Liv0_pantocheck_at_2;
    return sw_Comeng_SMU_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Comeng_SMU_Liv0_Trailer;
    3 : sw_Comeng_SMU_Liv0_pantocheck_at_1;
    4 : sw_Comeng_SMU_Liv0_sidecheck_4;
    5 : sw_Comeng_SMU_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Comeng_SMU_Liv0_sidecheck_6;
    return sw_Comeng_SMU_Liv0_sidecheck_other;
}

//End Cars
switch(FEAT_TRAINS, SELF, sw_Comeng_SMU_Liv0_panto_direction, vehicle_is_flipped){
