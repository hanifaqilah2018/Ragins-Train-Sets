        name:                           string(STR_NAME_TAITINTERURBAN);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              TaitInterurban_IntroDate;		
		length:                         TaitInterurban_Length;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							TaitInterurban_Speed km/h;
		cost_factor:					(TaitInterurban_CostFactor * 2);
		running_cost_factor:			(TaitInterurban_RunningCostFactor * 2);
		cargo_capacity: 				(TaitInterurban_CargoCapacity / param_capacity_mod);
		power:							(TaitInterurban_Power * 2);
		weight:							TaitInterurban_Weight ton;

        variant_group: 					Item_TaitInterurban_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_TaitInterurban_Liv3_frontcheck;
        purchase: 						switch_TaitInterurban_Liv3_PurchaseStack;
        additional_text: 				string(STR_INFO_TAITINTERURBAN);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_TaitInterurban_Liv3_lencheck ;
        length:							TaitInterurban_Length;
        cargo_capacity:                 [TaitInterurban_CargoCapacity / param_capacity_mod];
        power:                          TaitInterurban_Power;
		weight:                        	TaitInterurban_Weight;
		running_cost_factor:            TaitInterurban_RunningCostFactor;
    }
}

//ID
const TullochInterurban_ID = 13040;
//introduction_date
const TullochInterurban_IntroDate = date(1937, 1, 1);
//speed
const TullochInterurban_Speed = 115;
//cost_factor
const TullochInterurban_CostFactor = 24;
//running_cost_factor
const TullochInterurban_RunningCostFactor = 62;
//Cargo Capacity
const TullochInterurban_CargoCapacity = 76;
//power
const TullochInterurban_Power = 360;
//weight
const TullochInterurban_Weight = 50;
//Length
const TullochInterurban_Length = 8;

//Pantographs
spriteset(spriteset_TullochInterurban_Panto_Purchase,   "gfx/TullochInterurban_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_TullochInterurban_PantoDown,   "gfx/TullochInterurban_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_TullochInterurban_PantoDown_r,   "gfx/TullochInterurban_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_TullochInterurban_PantoUp,   "gfx/TullochInterurban_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_TullochInterurban_PantoUp_r,   "gfx/TullochInterurban_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_TullochInterurban_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_TullochInterurban_PantoDown;
 1: spriteset_TullochInterurban_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_TullochInterurban_Rw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_TullochInterurban_PantoDown_r; //might need switching back to just panto down
 1: spriteset_TullochInterurban_PantoUp_r;
}

//TullochInterurban_Liv0
spriteset(spriteset_TullochInterurban_Liv0_purchase,   "gfx/TullochInterurban_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_TullochInterurban_Liv0_lead,   "gfx/TullochInterurban_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_TullochInterurban_Liv0_lead_r,   "gfx/TullochInterurban_Liv0.png") {template_8_r(7, 39)}
spriteset(spriteset_TullochInterurban_Liv0_Trailer,   "gfx/TullochInterurban_Liv0.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_TullochInterurban_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TullochInterurban_Liv0_purchase;
	1: spriteset_TullochInterurban_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_TullochInterurban_Liv0_MotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TullochInterurban_Liv0_lead;
	1: switch_TullochInterurban_Fw_railtype;
}
//C Rear
switch (FEAT_TRAINS, SELF, switch_TullochInterurban_Liv0_MotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TullochInterurban_Liv0_lead;
	1: switch_TullochInterurban_Fw_railtype;
}

//N Lead
switch (FEAT_TRAINS, SELF, switch_TullochInterurban_Liv0_NonControlMotorStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TullochInterurban_Liv0_lead;
	1: switch_TullochInterurban_Fw_railtype;
}
//N Rear
switch (FEAT_TRAINS, SELF, switch_TullochInterurban_Liv0_NonControlMotorStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_TullochInterurban_Liv0_lead_r;
	1: switch_TullochInterurban_Rw_railtype;
}

//Midcars
switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_pantocheck_at_2, position_in_vehid_chain % 3){
    2 : switch_TullochInterurban_Liv0_NonControlMotorStack_r;
    return spriteset_TullochInterurban_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_TullochInterurban_Liv0_NonControlMotorStack;
    return spriteset_TullochInterurban_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_TullochInterurban_Liv0_NonControlMotorStack_r;
    return spriteset_TullochInterurban_Liv0_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_TullochInterurban_Liv0_NonControlMotorStack;
    return spriteset_TullochInterurban_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TullochInterurban_Liv0_pantocheck_at_1;
    return sw_TullochInterurban_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TullochInterurban_Liv0_pantocheck_at_1;
    return spriteset_TullochInterurban_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_TullochInterurban_Liv0_pantocheck_at_2;
    return sw_TullochInterurban_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_TullochInterurban_Liv0_Trailer;
    3 : sw_TullochInterurban_Liv0_pantocheck_at_1;
    4 : sw_TullochInterurban_Liv0_sidecheck_4;
    5 : sw_TullochInterurban_Liv0_pantocheck_at_2;
    6 .. 7 : sw_TullochInterurban_Liv0_sidecheck_6;
    return sw_TullochInterurban_Liv0_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_TullochInterurban_Liv0_MotorStack;        //Front panto
    return switch_TullochInterurban_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_TullochInterurban_Liv0_panto_direction;        //Not flipped, give Panto
    return spriteset_TullochInterurban_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_TullochInterurban_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_TullochInterurban_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_TullochInterurban_Liv0_panto_flipcheck; //More Checks
}

const TullochInterurban_ID_Liv0 = (TullochInterurban_ID + Liv0_ID);

item(FEAT_TRAINS, Item_TullochInterurban_Liv0, TullochInterurban_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_FictionalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TULLOCHINTERURBAN);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              TullochInterurban_IntroDate;		
		length:                         TullochInterurban_Length;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							TullochInterurban_Speed km/h;
		cost_factor:					(TullochInterurban_CostFactor * 2);
		running_cost_factor:			(TullochInterurban_RunningCostFactor * 2);
		cargo_capacity: 				(TullochInterurban_CargoCapacity / param_capacity_mod);
		power:							(TullochInterurban_Power * 2);
		weight:							TullochInterurban_Weight ton;

//        variant_group: 					Item_TullochInterurban_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_TullochInterurban_Liv0_frontcheck;
        purchase: 						switch_TullochInterurban_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_TULLOCHINTERURBAN);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_TullochInterurban_Liv0_lencheck ;
        length:							TullochInterurban_Length;
        cargo_capacity:                 [TullochInterurban_CargoCapacity / param_capacity_mod];
        power:                          TullochInterurban_Power;
		weight:                        	TullochInterurban_Weight;
		running_cost_factor:            TullochInterurban_RunningCostFactor;
    }
}

