const TullochSuburbanEMU_ID_Liv0 = (TullochSuburbanEMU_ID + Liv0_ID);

item(FEAT_TRAINS, Item_TullochSuburbanEMU_Liv0, TullochSuburbanEMU_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TULLOCHSUBURBANEMU);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              TullochSuburbanEMU_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							TullochSuburbanEMU_Speed km/h;
		cost_factor:					(TullochSuburbanEMU_CostFactor * 2);
		running_cost_factor:			(TullochSuburbanEMU_RunningCostFactor * 2);
		cargo_capacity: 				(TullochSuburbanEMU_CargoCapacity / param_capacity_mod);
		power:							(TullochSuburbanEMU_Power * 2);
		weight:							TullochSuburbanEMU_Weight ton;

//        variant_group: 					Item_TullochSuburbanEMU_MU_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_TullochSuburbanEMU_Liv0_frontcheck;
        purchase: 						switch_TullochSuburbanEMU_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_TULLOCHSUBURBANEMU);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_TullochSuburbanEMU_Liv0_lencheck ;
        length:							8;
        cargo_capacity:                 [TullochSuburbanEMU_CargoCapacity / param_capacity_mod];
        power:                          TullochSuburbanEMU_Power;
		weight:                        	TullochSuburbanEMU_Weight;
		running_cost_factor:            TullochSuburbanEMU_RunningCostFactor;

    }
}

//ID
const Harris_ID = 11200;
//introduction_date
const Harris_IntroDate = date(1956, 1, 1);
//speed
const Harris_Speed = 115;
//cost_factor
const Harris_CostFactor = 25;
//running_cost_factor
const Harris_RunningCostFactor = 52;
