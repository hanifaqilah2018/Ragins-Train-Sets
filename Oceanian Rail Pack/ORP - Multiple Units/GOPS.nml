 1: switch_Hitachi_PantoUp_Timeline_Rw;
}

//Hitachi_Liv0
spriteset(spriteset_Hitachi_Liv0_purchase,   "gfx/Hitachi_Liv0.png") {template_purchase_88mu(7, 21)}
