spriteset(spriteset_SputnikSuburbanEMU_PantoDown_r,   "gfx/SputnikSuburbanEMU_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_SputnikSuburbanEMU_PantoUp,   "gfx/SputnikSuburbanEMU_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_SputnikSuburbanEMU_PantoUp_r,   "gfx/SputnikSuburbanEMU_Pantographs.png") {template_8_r(7, 69)}

