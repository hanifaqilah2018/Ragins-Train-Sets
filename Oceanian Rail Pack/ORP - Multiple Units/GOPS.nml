spriteset(spriteset_DEBSet_Liv0_lead,   "gfx/DEBSet_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_DEBSet_Liv0_Trailer,   "gfx/DEBSet_Liv0.png") {template_8(7, 69)}
spriteset(spriteset_DEBSet_Liv0_Trailer_r,   "gfx/DEBSet_Liv0.png") {template_8_r(7, 69)}

 random_switch(FEAT_TRAINS, SELF, switch_DEBSet_Liv0_Trailer_Random){
    1 : spriteset_DEBSet_Liv0_Trailer;
    1 : spriteset_DEBSet_Liv0_Trailer_r;
}

const DEBSet_ID_Liv0 = (DEBSet_ID + Liv0_ID );

item(FEAT_TRAINS, Item_DEBSet_Liv0, DEBSet_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     RAIL;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_DIESEL;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_DIESEL;

        name:                           string(STR_NAME_DEBSET);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              DEBSet_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							DEBSet_Speed km/h;
		cost_factor:					(DEBSet_CostFactor * 2);
		running_cost_factor:			(DEBSet_RunningCostFactor * 2);
		cargo_capacity: 				(DEBSet_CargoCapacity / param_capacity_mod);
		power:							(DEBSet_Power * 2);
		weight:							DEBSet_Weight ton;

//        variant_group: 					Item_DEBSet_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						spriteset_DEBSet_Liv0_lead;
        purchase: 						spriteset_DEBSet_Liv0_purchase;
        additional_text: 				string(STR_INFO_DEBSET);
    }
    livery_override (Item_MU_Trailer){
        default: 						switch_DEBSet_Liv0_Trailer_Random ;
        length: 						8;
        cargo_capacity:                 (DEBSet_CargoCapacity / param_capacity_mod);
        power:                          DEBSet_Power;
		weight:                        	DEBSet_Weight;
		running_cost_factor:            DEBSet_RunningCostFactor;

    }
}

