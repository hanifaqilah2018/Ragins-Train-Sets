 0: spriteset_Tait_PantoDown;
 1: spriteset_Tait_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_Tait_Rw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Tait_PantoDown_r; //might need switching back to just panto down
 1: spriteset_Tait_PantoUp_r;
}
//Roof Controls
//Purchase
switch(FEAT_TRAINS, PARENT, switch_Tait_Roof_Transition_Purchase, current_year) {
    0..1929: spriteset_Tait_Roof1_Purchase;
	1929..2100: spriteset_Tait_Roof2_Purchase;
  return spriteset_Tait_Roof2_Purchase;
}

