		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_SYDNEYSTANDARDEMU);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              SydneyStandardEMU_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							SydneyStandardEMU_Speed km/h;
		cost_factor:					(SydneyStandardEMU_CostFactor * 2);
		running_cost_factor:			(SydneyStandardEMU_RunningCostFactor * 2);
		cargo_capacity: 				(SydneyStandardEMU_CargoCapacity / param_capacity_mod);
		power:							(SydneyStandardEMU_Power * 2);
		weight:							SydneyStandardEMU_Weight ton;

//        variant_group: 					Item_SydneyStandardEMU_MU_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_SydneyStandardEMU_Liv0_directioncheck;
        purchase: 						switch_SydneyStandardEMU_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_SYDNEYSTANDARDEMU);
    }
    livery_override (Item_MU_Trailer){
        default:						sw_SydneyStandardEMU_Liv0_revcheck ;
        length:							8;
        cargo_capacity:                 [SydneyStandardEMU_CargoCapacity / param_capacity_mod];
        power:                          SydneyStandardEMU_Power;
		weight:                        	SydneyStandardEMU_Weight;
		running_cost_factor:            SydneyStandardEMU_RunningCostFactor;

    }
}

//ID
const TullochSuburbanEMU_ID = 11180;
//introduction_date
const TullochSuburbanEMU_IntroDate = date(1940, 1, 1);
//speed
const TullochSuburbanEMU_Speed = 115;
//cost_factor
