    2 : switch_Comeng_VSet_Liv1_NonControlMotorStack_r;
    return spriteset_Comeng_VSet_Liv1_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_pantocheck_at_2r, position_in_vehid_chain_from_end % 3){
    2 : switch_Comeng_VSet_Liv1_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv1_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_pantocheck_at_1, position_in_vehid_chain % 2){
    1 : switch_Comeng_VSet_Liv1_NonControlMotorStack_r;
    return spriteset_Comeng_VSet_Liv1_Trailer;
}
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Comeng_VSet_Liv1_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv1_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv1_pantocheck_at_1;
    return sw_Comeng_VSet_Liv1_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv1_pantocheck_at_1;
    return spriteset_Comeng_VSet_Liv1_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv1_pantocheck_at_2;
    return sw_Comeng_VSet_Liv1_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Comeng_VSet_Liv1_Trailer;
    3 : sw_Comeng_VSet_Liv1_pantocheck_at_1;
    4 : sw_Comeng_VSet_Liv1_sidecheck_4;
    5 : sw_Comeng_VSet_Liv1_pantocheck_at_2;
    6 .. 7 : sw_Comeng_VSet_Liv1_sidecheck_6;
    return sw_Comeng_VSet_Liv1_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: switch_Comeng_VSet_Liv1_MotorStack; //Panto
    return spriteset_Comeng_VSet_Liv1_lead; //No Panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_panto_direction_r, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv1_panto_direction_r_pos;        //Front panto
    return switch_Comeng_VSet_Liv1_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_panto_flipcheck_r, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv1_panto_direction_r;        //Not flipped, give Panto
    return switch_Comeng_VSet_Liv1_MotorStack_r;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_frontcheck_r, position_in_vehid_chain){
    0: sw_Comeng_VSet_Liv1_panto_direction_r; //We need a pantograph, guaranteed
    return sw_Comeng_VSet_Liv1_panto_flipcheck_r; //More Checks
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_panto_direction, vehicle_is_flipped){
    0 : switch_Comeng_VSet_Liv1_MotorStack;        //Front panto
    return switch_Comeng_VSet_Liv1_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv1_panto_direction;        //Not flipped, give Panto
    return spriteset_Comeng_VSet_Liv1_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv1_frontcheck, position_in_vehid_chain){
    0: sw_Comeng_VSet_Liv1_panto_direction; //We need a pantograph, guaranteed
    return sw_Comeng_VSet_Liv1_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, sw_Comeng_VSet_Liv1_directioncheck, vehicle_is_reversed){
    0: sw_Comeng_VSet_Liv1_frontcheck; //We are going forwards
    return sw_Comeng_VSet_Liv1_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_Comeng_VSet_Liv1_revcheck, vehicle_is_reversed){
    0 : sw_Comeng_VSet_Liv1_lencheck;
    return sw_Comeng_VSet_Liv1_lencheck_r;
}

const Comeng_VSet_ID_Liv1 = (Comeng_VSet_ID + Liv1_ID );

item(FEAT_TRAINS, Item_Comeng_VSet_Liv1, Comeng_VSet_ID_Liv1) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_COMENG_VSET);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Comeng_VSet_IntroDate;		
		length:                         8;
		
		loading_speed:					DD_Intercity_LoadingSpeed;
		speed:							Comeng_VSet_Speed km/h;
		cost_factor:					(Comeng_VSet_CostFactor * 2);
		running_cost_factor:			(Comeng_VSet_RunningCostFactor * 2);
		cargo_capacity: 				(Comeng_VSet_CargoCapacity / param_capacity_mod);
		power:							(Comeng_VSet_Power * 2);
		weight:							Comeng_VSet_Weight ton;

        variant_group: 					Item_Comeng_VSet_Liv0;
        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Comeng_VSet_Liv1_directioncheck;
        purchase: 						switch_Comeng_VSet_Liv1_PurchaseStack;
        additional_text: 				string(STR_INFO_COMENG_VSET);
    }
    livery_override (Item_MU_Trailer){
        default: 						sw_Comeng_VSet_Liv1_revcheck ;
        length: 						8;
        cargo_capacity:                 (Comeng_VSet_CargoCapacity / param_capacity_mod);
        power:                          Comeng_VSet_Power;
		weight:                        	Comeng_VSet_Weight;
		running_cost_factor:            Comeng_VSet_RunningCostFactor;

    }
}

//ID
const ElectricTiltTrain_ID = 15060;
//introduction_date
const ElectricTiltTrain_IntroDate = date(1998, 1, 1);
//speed
const ElectricTiltTrain_Speed = 200;
//cost_factor
const ElectricTiltTrain_CostFactor = 37;
//running_cost_factor
const ElectricTiltTrain_RunningCostFactor = 97;
//Cargo Capacity
const ElectricTiltTrain_CargoCapacity = 79;
//power
const ElectricTiltTrain_Power = 614; //MU power is for 1 vehicle
//weight
const ElectricTiltTrain_Weight = 44;

//Pantographs
spriteset(spriteset_ElectricTiltTrain_Panto_Purchase,   "gfx/ElectricTiltTrain_Pantographs.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_ElectricTiltTrain_PantoDown,   "gfx/ElectricTiltTrain_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_ElectricTiltTrain_PantoDown_r,   "gfx/ElectricTiltTrain_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_ElectricTiltTrain_PantoUp,   "gfx/ElectricTiltTrain_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_ElectricTiltTrain_PantoUp_r,   "gfx/ElectricTiltTrain_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Fw_railtype, tile_powers_railtype("NG_RAIL_OHLE_AC")) {
 0: spriteset_ElectricTiltTrain_PantoDown;
 1: spriteset_ElectricTiltTrain_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Rw_railtype, tile_powers_railtype("NG_RAIL_OHLE_AC")) {
 0: spriteset_ElectricTiltTrain_PantoDown_r; //might need switching back to just panto down
 1: spriteset_ElectricTiltTrain_PantoUp_r;
}

//ElectricTiltTrain_Liv0
spriteset(spriteset_ElectricTiltTrain_Liv0_purchase,   "gfx/ElectricTiltTrain_Liv0.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_ElectricTiltTrain_Liv0_lead,   "gfx/ElectricTiltTrain_Liv0.png") {template_8(7, 39)}
spriteset(spriteset_ElectricTiltTrain_Liv0_lead_r,   "gfx/ElectricTiltTrain_Liv0.png") {template_8_r(7, 39)}
spriteset(spriteset_ElectricTiltTrain_Liv0_Trailer,   "gfx/ElectricTiltTrain_Liv0.png") {template_8_repeat(7, 69)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ElectricTiltTrain_Liv0_purchase;
	1: spriteset_ElectricTiltTrain_Panto_Purchase;
}

//C Lead
switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_LeadStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ElectricTiltTrain_Liv0_lead;
	1: switch_ElectricTiltTrain_Fw_railtype;
}

//Pantograph cars
//Swap normal & _r cars to swap pantograph arrangements
switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_PantoCarStack_r, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ElectricTiltTrain_Liv0_Trailer;
	1: switch_ElectricTiltTrain_Fw_railtype;
}

switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_PantoCarStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_ElectricTiltTrain_Liv0_Trailer;
	1: switch_ElectricTiltTrain_Rw_railtype;
}

/* Midcars */
    // Backwards
        // Penultipantos
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_pantos_large_backwards, position_in_vehid_chain_from_end ) {
                0:  switch_ElectricTiltTrain_Liv0_PantoCarStack_r;
                switch_ElectricTiltTrain_Liv0_PantoCarStack;
            }
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_backwards_length_large, (position_in_vehid_chain == 0) || (position_in_vehid_chain_from_end == 0 )) {                
                1:  switch_ElectricTiltTrain_Liv0_pantos_large_backwards;
                spriteset_ElectricTiltTrain_Liv0_Trailer;            
            }
        //Panto in Middle
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_backwards_length_small, (position_in_vehid_chain == position_in_vehid_chain_from_end ) || (position_in_vehid_chain - 1 == position_in_vehid_chain_from_end) ) {                
                0:  switch_ElectricTiltTrain_Liv0_PantoCarStack_r;
                spriteset_ElectricTiltTrain_Liv0_Trailer;                    
            }
    switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_backwards_length, num_vehs_in_vehid_chain) {
            0..1: switch_ElectricTiltTrain_Liv0_backwards_length_large;
            2: switch_ElectricTiltTrain_Liv0_backwards_length_small;
            switch_ElectricTiltTrain_Liv0_backwards_length_large;
        }

    // Forwards
        // Penultipantos
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_pantos_large_forwards, position_in_vehid_chain ) {                
                0:  switch_ElectricTiltTrain_Liv0_PantoCarStack;
                switch_ElectricTiltTrain_Liv0_PantoCarStack_r;          
            }
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_forwards_length_large, (position_in_vehid_chain == 0) || (position_in_vehid_chain_from_end == 0 )) {                
                1:  switch_ElectricTiltTrain_Liv0_pantos_large_forwards;
                spriteset_ElectricTiltTrain_Liv0_Trailer;        
            }
        // Panto in Middle
        switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_forwards_length_small, (position_in_vehid_chain == position_in_vehid_chain_from_end ) || (position_in_vehid_chain - 1 == position_in_vehid_chain_from_end) ) {                
                0:  spriteset_ElectricTiltTrain_Liv0_Trailer;
                switch_ElectricTiltTrain_Liv0_PantoCarStack;                
            }
    switch (FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_forwards_length, num_vehs_in_vehid_chain) {
            0..1: switch_ElectricTiltTrain_Liv0_forwards_length_large;
            2:  switch_ElectricTiltTrain_Liv0_forwards_length_small;
            switch_ElectricTiltTrain_Liv0_forwards_length_large;
        }

    switch (FEAT_TRAINS, PARENT, switch_ElectricTiltTrain_Liv0_midcars, vehicle_is_reversed) {                
            0:  switch_ElectricTiltTrain_Liv0_forwards_length;
            switch_ElectricTiltTrain_Liv0_backwards_length;                
        }
	


//End Car Controls
//Forwards
switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: spriteset_ElectricTiltTrain_Liv0_lead; //Panto
    return switch_ElectricTiltTrain_Liv0_LeadStack; //No Panto
}

switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : switch_ElectricTiltTrain_Liv0_panto_direction_r_pos;        //Front panto
    return spriteset_ElectricTiltTrain_Liv0_lead;    //Rear panto
}

switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : switch_ElectricTiltTrain_Liv0_panto_direction_r;        //Not flipped, give Panto
    return spriteset_ElectricTiltTrain_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_frontcheck_r, position_in_vehid_chain){
    0: switch_ElectricTiltTrain_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return switch_ElectricTiltTrain_Liv0_panto_flipcheck_r; //More Checks
}

//Backwardss
switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : spriteset_ElectricTiltTrain_Liv0_lead;        //Not flipped, give Panto
    return switch_ElectricTiltTrain_Liv0_LeadStack;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, switch_ElectricTiltTrain_Liv0_frontcheck, position_in_vehid_chain){
    0: spriteset_ElectricTiltTrain_Liv0_lead; //We need a pantograph, guaranteed
    return switch_ElectricTiltTrain_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, switch_ElectricTiltTrain_Liv0_directioncheck, vehicle_is_reversed){
    0: switch_ElectricTiltTrain_Liv0_frontcheck; //We are going forwards
    return switch_ElectricTiltTrain_Liv0_frontcheck_r; //We are going backwards
}

const ElectricTiltTrain_ID_Liv0 = (ElectricTiltTrain_ID + Liv0_ID);

item(FEAT_TRAINS, Item_ElectricTiltTrain_Liv0, ElectricTiltTrain_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_TILT,TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     NG_RAIL_OHLE_AC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_ProposalDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_ELECTRICTILTTRAIN);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              ElectricTiltTrain_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Intercity_LoadingSpeed;
		speed:							ElectricTiltTrain_Speed km/h;
		cost_factor:					(ElectricTiltTrain_CostFactor * 2);
		running_cost_factor:			(ElectricTiltTrain_RunningCostFactor * 2);
		cargo_capacity: 				(ElectricTiltTrain_CargoCapacity / param_capacity_mod);
		power:							(ElectricTiltTrain_Power * 2);
		weight:							ElectricTiltTrain_Weight ton;

//        variant_group: 					Item_ElectricTiltTrain_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_ElectricTiltTrain_Liv0_directioncheck;
        purchase: 						switch_ElectricTiltTrain_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_ELECTRICTILTTRAIN);
    }
    livery_override (Item_MU_Trailer){
        default:						switch_ElectricTiltTrain_Liv0_midcars;
        length:							8;
        cargo_capacity:                 [ElectricTiltTrain_CargoCapacity / param_capacity_mod];
        power:                          ElectricTiltTrain_Power;
		weight:                        	ElectricTiltTrain_Weight;
		running_cost_factor:            ElectricTiltTrain_RunningCostFactor;

    }
}