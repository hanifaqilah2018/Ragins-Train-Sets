//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Tait_Fw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Tait_PantoDown;
 1: spriteset_Tait_PantoUp;
}

switch(FEAT_TRAINS, SELF, switch_Tait_Rw_railtype, tile_powers_railtype("BG_RAIL_OHLE_DC")) {
 0: spriteset_Tait_PantoDown_r; //might need switching back to just panto down
 1: spriteset_Tait_PantoUp_r;
}
//Roof Controls
//Purchase
switch(FEAT_TRAINS, PARENT, switch_Tait_Roof_Transition_Purchase, date_of_last_service) {
    0..date(1928, 12, 31): spriteset_Tait_Roof1_Purchase;
	date(1929, 1, 1)..date(2100, 1, 1): spriteset_Tait_Roof2_Purchase;
  return spriteset_Tait_Roof2_Purchase;
}

//Motor Forward
random_switch(FEAT_TRAINS, SELF, switch_Tait_Roof_Transition_Motor_Random){
    3 : spriteset_Tait_Roof1_Motor;
	1 : spriteset_Tait_Roof2_Motor;
}

switch(FEAT_TRAINS, PARENT, switch_Tait_Roof_Transition_Motor, date_of_last_service) {
