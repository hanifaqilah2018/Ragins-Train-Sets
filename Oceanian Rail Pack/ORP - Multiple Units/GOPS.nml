switch(FEAT_TRAINS, PARENT, switch_Hitachi_Panto_Purchase, current_year) {
    0..1973: spriteset_Hitachi_SinglePanto_Purchase;
	1974..2100: spriteset_Hitachi_DiamondPanto_Purchase;
