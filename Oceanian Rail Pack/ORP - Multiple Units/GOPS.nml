//ID
const Tait_ID = 11080;
//introduction_date
const Tait_IntroDate = date(1919, 1, 1);
//speed
const Tait_Speed = 80; //verify at a later date, 110 km/h seems rather high
//cost_factor
const Tait_CostFactor = 18;
//running_cost_factor
const Tait_RunningCostFactor = 47;
//Cargo Capacity
const Tait_CargoCapacity = 88;
//power
const Tait_Power = 282;
//weight
const Tait_Weight = 35;

//Pantographs
//Single
spriteset(spriteset_Tait_Panto_Single_Purchase,   "gfx/Tait_Pantographs.png") {template_purchase_8(7, 21)}

spriteset(spriteset_Tait_Roof1_Single_Purchase,   "gfx/Tait_Roof1.png") {template_purchase_8(187, 21)}
spriteset(spriteset_Tait_Roof2_Single_Purchase,   "gfx/Tait_Roof2.png") {template_purchase_8(187, 21)}

//MU
spriteset(spriteset_Tait_Panto_Purchase,   "gfx/Tait_Pantographs.png") {template_purchase_88mu(7, 21)}

spriteset(spriteset_Tait_PantoDown,   "gfx/Tait_Pantographs.png") {template_8(7, 39)}
spriteset(spriteset_Tait_PantoDown_r,   "gfx/Tait_Pantographs.png") {template_8_r(7, 39)}
spriteset(spriteset_Tait_PantoUp,   "gfx/Tait_Pantographs.png") {template_8(7, 69)}
spriteset(spriteset_Tait_PantoUp_r,   "gfx/Tait_Pantographs.png") {template_8_r(7, 69)}

spriteset(spriteset_Tait_Roof1_Purchase,   "gfx/Tait_Roof1.png") {template_purchase_88mu(7, 21)}
spriteset(spriteset_Tait_Roof1_Motor,   "gfx/Tait_Roof1.png") {template_8(7, 39)}
spriteset(spriteset_Tait_Roof1_Motor_r,   "gfx/Tait_Roof1.png") {template_8_r(7, 39)}
spriteset(spriteset_Tait_Roof1_Trailer,   "gfx/Tait_Roof1.png") {template_8_repeat(7, 69)}


spriteset(spriteset_Tait_Roof2_Purchase,   "gfx/Tait_Roof2.png") {template_purchase_88mu(7, 21)}
