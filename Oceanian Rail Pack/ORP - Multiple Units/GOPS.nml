//Purchase Panto Control
switch(FEAT_TRAINS, PARENT, switch_Hitachi_Panto_Purchase, current_year) {
    0..1973: spriteset_Hitachi_SinglePanto_Purchase;
	1974..2100: spriteset_Hitachi_DiamondPanto_Purchase;
  return spriteset_Hitachi_DiamondPanto_Purchase;
}

//Pantograph Randomisers
//Forward Up 1974-1981
random_switch(FEAT_TRAINS, SELF, switch_Hitachi_PantoUp_Mid_Fw_Random){
    1 : spriteset_Hitachi_SinglePantoUp;
	3 : spriteset_Hitachi_DiamondPantoUp;
}

//Forward Up 1981-2014
random_switch(FEAT_TRAINS, SELF, switch_Hitachi_PantoUp_Late_Fw_Random){
    4 : spriteset_Hitachi_SinglePantoUp;
	4 : spriteset_Hitachi_DiamondPantoUp;
	1 : spriteset_Hitachi_SinglePantoUpAlt;
	1 : spriteset_Hitachi_DiamondPantoUp_r;
}

//Forward Up Timeline
switch(FEAT_TRAINS, PARENT, switch_Hitachi_PantoUp_Timeline_Fw, date_of_last_service) {
    0..date(1973, 12, 31): spriteset_Hitachi_SinglePantoUp;
	date(1974, 1, 1)..date(1980, 12, 31): switch_Hitachi_PantoUp_Mid_Fw_Random;
	date(1981, 1, 1)..date(9999, 12, 31): switch_Hitachi_PantoUp_Late_Fw_Random;
  return switch_Hitachi_PantoUp_Late_Fw_Random;
}

