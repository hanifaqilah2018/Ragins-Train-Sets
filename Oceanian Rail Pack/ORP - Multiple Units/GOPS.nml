}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Goninan_Tangara_Liv0_pantocheck_at_2;
    return sw_Goninan_Tangara_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Goninan_Tangara_Liv0_Trailer;
    3 : sw_Goninan_Tangara_Liv0_pantocheck_at_1;
    4 : sw_Goninan_Tangara_Liv0_sidecheck_4;
    5 : sw_Goninan_Tangara_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Goninan_Tangara_Liv0_sidecheck_6;
    return sw_Goninan_Tangara_Liv0_sidecheck_other;
}

//Endcars
switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Goninan_Tangara_Liv0_MotorStack;        //Front panto
    return switch_Goninan_Tangara_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Goninan_Tangara_Liv0_panto_direction;        //Not flipped, give Panto
    return spriteset_Goninan_Tangara_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Goninan_Tangara_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Goninan_Tangara_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_Goninan_Tangara_Liv0_panto_flipcheck; //More Checks
}

