spriteset(spriteset_Goninan_Tangara_PantoUp_r,   "gfx/Goninan_Tangara_Pantographs.png") {template_8_r(7, 69)}

//Pantograph Controls
switch(FEAT_TRAINS, SELF, switch_Goninan_Tangara_Fw_railtype, tile_powers_railtype("OHLE_DC")) {
 0: spriteset_Goninan_Tangara_PantoDown;
 1: spriteset_Goninan_Tangara_PantoUp;
}

