//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Tait_Single_Liv0_Purchasestack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_single_purchase;
	1: switch_Tait_Roof_Transition_Single_Purchase;
	2: spriteset_Tait_Panto_Single_Purchase;
}

//Sprite Stack
switch (FEAT_TRAINS, SELF, switch_Tait_Single_Liv0_stack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_single;
	1: switch_Tait_Roof_Transition_Single;
	2: switch_Tait_Fw_railtype;
}

const Tait_ID_Single_Liv0 = (Tait_ID + Liv0_ID);

item(FEAT_TRAINS, Item_Tait_Single_Liv0, Tait_ID_Single_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     BG_RAIL_OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_TAIT);
		
		refit_cost:                     0;
        dual_headed:                    0;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Tait_IntroDate;		
		length:                         8;
		
		loading_speed:					SD_Suburban_LoadingSpeed;
		speed:							Tait_Speed km/h;
		cost_factor:					Tait_CostFactor;
		running_cost_factor:			Tait_RunningCostFactor;
		cargo_capacity: 				Tait_CargoCapacity;
		power:							Tait_Power;
		weight:							Tait_Weight ton;

//        variant_group: 					Item_Tait_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						switch_Tait_Single_Liv0_stack;
        purchase: 						switch_Tait_Single_Liv0_Purchasestack;
        additional_text: 				string(STR_INFO_TAIT);
		reverse_build_probability: 		return 50;
}
}

//Tait_Liv0 Multiple Unit
//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Tait_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 3 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Tait_Liv0_purchase;
	1: switch_Tait_Roof_Transition_Purchase;
	2: spriteset_Tait_Panto_Purchase;
}

//C Lead
