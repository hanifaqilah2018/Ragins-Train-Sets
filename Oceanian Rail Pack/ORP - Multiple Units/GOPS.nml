}
switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_pantocheck_at_1r, position_in_vehid_chain_from_end % 2){
    1 : switch_Comeng_VSet_Liv0_NonControlMotorStack;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_other, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv0_pantocheck_at_1;
    return sw_Comeng_VSet_Liv0_pantocheck_at_1r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_4, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv0_pantocheck_at_1;
    return spriteset_Comeng_VSet_Liv0_Trailer;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_sidecheck_6, num_vehs_in_vehid_chain/2 > position_in_vehid_chain ) {
    1 : sw_Comeng_VSet_Liv0_pantocheck_at_2;
    return sw_Comeng_VSet_Liv0_pantocheck_at_2r;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_lencheck, num_vehs_in_vehid_chain ) {
    0 .. 2 : spriteset_Comeng_VSet_Liv0_Trailer;
    3 : sw_Comeng_VSet_Liv0_pantocheck_at_1;
    4 : sw_Comeng_VSet_Liv0_sidecheck_4;
    5 : sw_Comeng_VSet_Liv0_pantocheck_at_2;
    6 .. 7 : sw_Comeng_VSet_Liv0_sidecheck_6;
    return sw_Comeng_VSet_Liv0_sidecheck_other;
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_panto_direction_r_pos, position_in_vehid_chain_from_end){
    0: switch_Comeng_VSet_Liv0_MotorStack; //Panto
    return spriteset_Comeng_VSet_Liv0_lead; //No Panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_panto_direction_r, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv0_panto_direction_r_pos;        //Front panto
    return switch_Comeng_VSet_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_panto_flipcheck_r, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv0_panto_direction_r;        //Not flipped, give Panto
    return switch_Comeng_VSet_Liv0_MotorStack_r;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_frontcheck_r, position_in_vehid_chain){
    0: sw_Comeng_VSet_Liv0_panto_direction_r; //We need a pantograph, guaranteed
    return sw_Comeng_VSet_Liv0_panto_flipcheck_r; //More Checks
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_panto_direction, vehicle_is_flipped){
    0 : switch_Comeng_VSet_Liv0_MotorStack;        //Front panto
    return switch_Comeng_VSet_Liv0_MotorStack_r;    //Rear panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_panto_flipcheck, vehicle_is_flipped){
    0 : sw_Comeng_VSet_Liv0_panto_direction;        //Not flipped, give Panto
    return spriteset_Comeng_VSet_Liv0_lead;    //Flipped, no panto
}

switch(FEAT_TRAINS, SELF, sw_Comeng_VSet_Liv0_frontcheck, position_in_vehid_chain){
    0: sw_Comeng_VSet_Liv0_panto_direction; //We need a pantograph, guaranteed
    return sw_Comeng_VSet_Liv0_panto_flipcheck; //More Checks
}

switch(FEAT_TRAINS, PARENT, sw_Comeng_VSet_Liv0_directioncheck, vehicle_is_reversed){
    0: sw_Comeng_VSet_Liv0_frontcheck; //We are going forwards
    return sw_Comeng_VSet_Liv0_frontcheck_r; //We are going backwards
}

switch(FEAT_TRAINS, PARENT, sw_Comeng_VSet_Liv0_revcheck, vehicle_is_reversed){
    0 : sw_Comeng_VSet_Liv0_lencheck;
    return sw_Comeng_VSet_Liv0_lencheck_r;
}

const Comeng_VSet_ID_Liv0 = (Comeng_VSet_ID + Liv0_ID );

item(FEAT_TRAINS, Item_Comeng_VSet_Liv0, Comeng_VSet_ID_Liv0) {
    property {
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
		misc_flags:                     bitmask(TRAIN_FLAG_MU,TRAIN_FLAG_2CC, TRAIN_FLAG_SPRITE_STACK); // <- Train Flag MU needed here
		track_type:                     OHLE_DC;
		running_cost_base:              RUNNING_COST_ELECTRIC;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        ai_special_flag:                AI_FLAG_PASSENGER;
		bitmask_vehicle_info:           0;
	
		climates_available:             (param_RealDisable == 0) ? ALL_CLIMATES : NO_CLIMATE;
		refittable_cargo_classes:       CC_PASSENGERS;
		default_cargo_type:				PASS;
		cargo_allow_refit:              [PASS, TOUR];
		visual_effect_and_powered: 		VISUAL_EFFECT_ELECTRIC;

        name:                           string(STR_NAME_COMENG_VSET);
		
		refit_cost:                     0;
        dual_headed:                    1;
        air_drag_coefficient:           0.08;
        model_life:                     30;
		vehicle_life:                   50;
		tractive_effort_coefficient:	0.3;
		
        introduction_date:              Comeng_VSet_IntroDate;		
		length:                         8;
		
		loading_speed:					DD_Intercity_LoadingSpeed;
		speed:							Comeng_VSet_Speed km/h;
		cost_factor:					(Comeng_VSet_CostFactor * 2);
		running_cost_factor:			(Comeng_VSet_RunningCostFactor * 2);
		cargo_capacity: 				(Comeng_VSet_CargoCapacity / param_capacity_mod);
		power:							(Comeng_VSet_Power * 2);
		weight:							Comeng_VSet_Weight ton;

//        variant_group: 					Item_Comeng_VSet_Liv0;
//        extra_flags:  					bitmask (VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
    }
    graphics {
        default: 						sw_Comeng_VSet_Liv0_directioncheck;
        purchase: 						switch_Comeng_VSet_Liv0_PurchaseStack;
        additional_text: 				string(STR_INFO_COMENG_VSET);
    }
    livery_override (Item_MU_Trailer){
        default: 						sw_Comeng_VSet_Liv0_revcheck ;
        length: 						8;
        cargo_capacity:                 (Comeng_VSet_CargoCapacity / param_capacity_mod);
        power:                          Comeng_VSet_Power;
		weight:                        	Comeng_VSet_Weight;
		running_cost_factor:            Comeng_VSet_RunningCostFactor;

    }
}

