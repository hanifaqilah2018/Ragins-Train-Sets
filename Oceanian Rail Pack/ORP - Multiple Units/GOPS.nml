spriteset(spriteset_Harris_Liv0_Trailer,   "gfx/Harris_Liv0.png") {template_8_repeat(7, 99)}
spriteset(spriteset_Harris_Liv0_3door_Trailer,   "gfx/Harris_Liv0.png") {template_8_repeat(7, 129)}

//Purchase Stack
switch (FEAT_TRAINS, SELF, switch_Harris_Liv0_PurchaseStack, [
    STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100),
    getbits(extra_callback_info1, 8, 8)
    ]) {
    0: spriteset_Harris_Liv0_purchase;
	1: spriteset_Harris_Panto_Purchase;
}

//Randomisers
random_switch(FEAT_TRAINS, SELF, switch_Harris_Liv0_lead_Random){
    1 : spriteset_Harris_Liv0_lead;
	1 : spriteset_Harris_Liv0_3door_lead;
}

random_switch(FEAT_TRAINS, SELF, switch_Harris_Liv0_lead_r_Random){
    1 : spriteset_Harris_Liv0_lead_r;
	1 : spriteset_Harris_Liv0_3door_lead_r;
}

random_switch(FEAT_TRAINS, SELF, switch_Harris_Liv0_Trailer_Random){
    1 : spriteset_Harris_Liv0_Trailer;
	1 : spriteset_Harris_Liv0_3door_Trailer;
}

